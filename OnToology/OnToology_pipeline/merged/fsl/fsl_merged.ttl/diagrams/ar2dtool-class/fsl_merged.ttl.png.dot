	"tbox:IssueEntity" -> "rdf:langString" [ label = "tbox:critique" ];
	"tbox:LanguageEntity" -> "tbox:ToolEntity" [ label = "tbox:isTargetedBy" ];
	"tbox:LanguageEntity" -> "tbox:LanguageConcept" [ label = "tbox:standardlySupports" ];
	"tbox:LanguageEntity" -> "tbox:ArtifactEntity" [ label = "tbox:hasElement" ];

}
