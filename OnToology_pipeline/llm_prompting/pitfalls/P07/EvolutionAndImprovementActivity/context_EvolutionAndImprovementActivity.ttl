#################################################################

###  http://www.softlang.org/ontologies/tbox#metamodelingPolicy
tbox:metamodelingPolicy rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2000/01/rdf-schema#comment
rdfs:comment rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2000/01/rdf-schema#label
rdfs:label rdf:type owl:AnnotationProperty .


###  http://xmlns.com/foaf/0.1/isPrimaryTopicOf
foaf:isPrimaryTopicOf rdf:type owl:AnnotationProperty .


###  http://xmlns.com/foaf/0.1/page
foaf:page rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.softlang.org/ontologies/tbox#hasAffectedArtifact
tbox:hasAffectedArtifact rdf:type owl:ObjectProperty .


###  http://www.softlang.org/ontologies/tbox#hasSupportingLanguage
tbox:hasSupportingLanguage rdf:type owl:ObjectProperty .


###  http://www.softlang.org/ontologies/tbox#hasSupportingTool
tbox:hasSupportingTool rdf:type owl:ObjectProperty .


###  http://www.softlang.org/ontologies/tbox#uses
tbox:uses rdf:type owl:ObjectProperty .


###  http://xmlns.com/foaf/0.1/isPrimaryTopicOf
foaf:isPrimaryTopicOf rdf:type owl:ObjectProperty .


###  http://xmlns.com/foaf/0.1/page
foaf:page rdf:type owl:ObjectProperty .


#################################################################
#    Classes
#################################################################

###  http://www.softlang.org/ontologies/ce#ChangeManagement
ce:ChangeManagement rdf:type owl:Class ;
                    rdfs:subClassOf ce:EvolutionAndImprovementActivity .


###  http://www.softlang.org/ontologies/ce#EvolutionAndImprovementActivity
ce:EvolutionAndImprovementActivity rdf:type owl:Class ;
                                   rdfs:subClassOf tbox:EngineeringActivity .


###  http://www.softlang.org/ontologies/ce#FeatureEnhancement
ce:FeatureEnhancement rdf:type owl:Class ;
                      rdfs:subClassOf ce:EvolutionAndImprovementActivity .


###  http://www.softlang.org/ontologies/ce#ImplementationActivity
ce:ImplementationActivity rdf:type owl:Class .


###  http://www.softlang.org/ontologies/ce#Migration
ce:Migration rdf:type owl:Class ;
             rdfs:subClassOf ce:EvolutionAndImprovementActivity .


###  http://www.softlang.org/ontologies/ce#Reengineering
ce:Reengineering rdf:type owl:Class ;
                 rdfs:subClassOf ce:EvolutionAndImprovementActivity .


###  http://www.softlang.org/ontologies/ce#Refactoring
ce:Refactoring rdf:type owl:Class ;
               rdfs:subClassOf ce:EvolutionAndImprovementActivity ,
                               ce:ImplementationActivity .


###  http://www.softlang.org/ontologies/ce#TechnicalDebtManagement
ce:TechnicalDebtManagement rdf:type owl:Class ;
                           rdfs:subClassOf ce:EvolutionAndImprovementActivity .


###  http://www.softlang.org/ontologies/tbox#ConceptualEntity
tbox:ConceptualEntity rdf:type owl:Class ;
                      rdfs:subClassOf tbox:Entity ;
                      tbox:metamodelingPolicy "All non-immediate subclasses must also be of this type."@en ;
                      rdfs:comment "Contextual concepts for other entity types (foundations, languages, tools, and artifacts)"@en ;
                      rdfs:label "Conceptual entity"@en .


###  http://www.softlang.org/ontologies/tbox#EngineeringActivity
tbox:EngineeringActivity rdf:type owl:Class ;
                         rdfs:subClassOf tbox:ConceptualEntity .


###  http://www.softlang.org/ontologies/tbox#Entity
tbox:Entity rdf:type owl:Class ;
            rdfs:subClassOf owl:Thing .


###  http://www.softlang.org/ontologies/tbox#PropertyEntity
tbox:PropertyEntity rdf:type owl:Class .


#################################################################
#    Individuals
#################################################################

###  http://www.softlang.org/ontologies/ae#ProgramArtifact
ae:ProgramArtifact rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#ChangeManagement
ce:ChangeManagement rdf:type owl:NamedIndividual ,
                             tbox:ConceptualEntity ;
                    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Change_management> .


###  http://www.softlang.org/ontologies/ce#EvolutionAndImprovementActivity
ce:EvolutionAndImprovementActivity rdf:type owl:NamedIndividual ,
                                            tbox:ConceptualEntity ;
                                   foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Software_evolution> .


###  http://www.softlang.org/ontologies/ce#FeatureEnhancement
ce:FeatureEnhancement rdf:type owl:NamedIndividual ,
                               tbox:ConceptualEntity ;
                      foaf:page <https://en.wikipedia.org/wiki/Software_evolution> .


###  http://www.softlang.org/ontologies/ce#Migration
ce:Migration rdf:type owl:NamedIndividual ,
                      tbox:ConceptualEntity ;
             foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Migration_(software)> .


###  http://www.softlang.org/ontologies/ce#Reengineering
ce:Reengineering rdf:type owl:NamedIndividual ,
                          tbox:ConceptualEntity ;
                 foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Reengineering> .


###  http://www.softlang.org/ontologies/ce#Refactoring
ce:Refactoring rdf:type owl:NamedIndividual ,
                        tbox:ConceptualEntity ;
               tbox:hasAffectedArtifact ae:ProgramArtifact ;
               tbox:hasSupportingLanguage pe:ProgrammingLanguage ;
               tbox:hasSupportingTool te:RefactoringTool ;
               tbox:uses fe:SoftwareDesignApproach ;
               foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Code_refactoring> .


###  http://www.softlang.org/ontologies/ce#TechnicalDebtManagement
ce:TechnicalDebtManagement rdf:type owl:NamedIndividual ,
                                    tbox:ConceptualEntity ;
                           foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Technical_debt> .


###  http://www.softlang.org/ontologies/fe#SoftwareDesignApproach
fe:SoftwareDesignApproach rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/pe#ProgrammingLanguage
pe:ProgrammingLanguage rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/tbox#EngineeringActivity
tbox:EngineeringActivity rdf:type owl:NamedIndividual ,
                                  tbox:ConceptualEntity ;
                         foaf:page <https://en.wikipedia.org/wiki/Software_development_process> .


###  http://www.softlang.org/ontologies/tbox#Entity
tbox:Entity rdf:type owl:NamedIndividual ;
            foaf:page <https://en.wikipedia.org/wiki/Knowledge_representation_and_reasoning> .


###  http://www.softlang.org/ontologies/tbox#hasAffectedArtifact
tbox:hasAffectedArtifact rdf:type owl:NamedIndividual ,
                                  tbox:PropertyEntity .


###  http://www.softlang.org/ontologies/tbox#hasSupportingLanguage
tbox:hasSupportingLanguage rdf:type owl:NamedIndividual ,
                                    tbox:PropertyEntity .


###  http://www.softlang.org/ontologies/tbox#hasSupportingTool
tbox:hasSupportingTool rdf:type owl:NamedIndividual ,
                                tbox:PropertyEntity .


###  http://www.softlang.org/ontologies/tbox#metamodelingPolicy
tbox:metamodelingPolicy rdf:type owl:NamedIndividual ,
                                 tbox:PropertyEntity ;
                        foaf:page <https://en.wikipedia.org/wiki/Guideline> .


###  http://www.softlang.org/ontologies/tbox#uses
tbox:uses rdf:type owl:NamedIndividual ,
                   tbox:PropertyEntity .


###  http://www.softlang.org/ontologies/te#RefactoringTool
te:RefactoringTool rdf:type owl:NamedIndividual .


