@prefix : <http://www.softlang.org/ontologies/fsl#> .
@prefix ae: <http://www.softlang.org/ontologies/ae#> .
@prefix ce: <http://www.softlang.org/ontologies/ce#> .
@prefix fe: <http://www.softlang.org/ontologies/fe#> .
@prefix ie: <http://www.softlang.org/ontologies/ie#> .
@prefix le: <http://www.softlang.org/ontologies/le#> .
@prefix pe: <http://www.softlang.org/ontologies/pe#> .
@prefix te: <http://www.softlang.org/ontologies/te#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix tbox: <http://www.softlang.org/ontologies/tbox#> .
@base <http://www.softlang.org/ontologies/fsl> .

<http://www.softlang.org/ontologies/fsl> rdf:type owl:Ontology .

#################################################################
#    Annotation properties
#################################################################

###  http://www.softlang.org/ontologies/tbox#metamodelingPolicy
tbox:metamodelingPolicy rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2000/01/rdf-schema#comment
rdfs:comment rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2000/01/rdf-schema#label
rdfs:label rdf:type owl:AnnotationProperty .


###  http://xmlns.com/foaf/0.1/page
foaf:page rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.softlang.org/ontologies/tbox#hasArea
tbox:hasArea rdf:type owl:ObjectProperty .


###  http://www.softlang.org/ontologies/tbox#hasArtifact
tbox:hasArtifact rdf:type owl:ObjectProperty .


###  http://www.softlang.org/ontologies/tbox#hasSpace
tbox:hasSpace rdf:type owl:ObjectProperty .


###  http://www.softlang.org/ontologies/tbox#hasTool
tbox:hasTool rdf:type owl:ObjectProperty .


###  http://www.softlang.org/ontologies/tbox#serves
tbox:serves rdf:type owl:ObjectProperty .


###  http://www.softlang.org/ontologies/tbox#uses
tbox:uses rdf:type owl:ObjectProperty .


###  http://xmlns.com/foaf/0.1/isPrimaryTopicOf
foaf:isPrimaryTopicOf rdf:type owl:ObjectProperty .


###  http://xmlns.com/foaf/0.1/page
foaf:page rdf:type owl:ObjectProperty .


#################################################################
#    Classes
#################################################################

###  http://www.softlang.org/ontologies/fe#DomainTheory
fe:DomainTheory rdf:type owl:Class ;
                rdfs:subClassOf fe:Theory .


###  http://www.softlang.org/ontologies/fe#FormalSemanticsApproach
fe:FormalSemanticsApproach rdf:type owl:Class .


###  http://www.softlang.org/ontologies/fe#Theory
fe:Theory rdf:type owl:Class ;
          rdfs:subClassOf tbox:FormalEntity .


###  http://www.softlang.org/ontologies/tbox#ConceptualEntity
tbox:ConceptualEntity rdf:type owl:Class .


###  http://www.softlang.org/ontologies/tbox#Entity
tbox:Entity rdf:type owl:Class ;
            rdfs:subClassOf owl:Thing .


###  http://www.softlang.org/ontologies/tbox#FormalEntity
tbox:FormalEntity rdf:type owl:Class ;
                  rdfs:subClassOf tbox:Entity ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty tbox:hasArea ;
                                    owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onClass tbox:SubjectArea
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty tbox:hasSpace ;
                                    owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onClass tbox:TechnologicalSpace
                                  ] ;
                  tbox:metamodelingPolicy "All non-immediate subclasses must also be of this type."@en ;
                  rdfs:comment "Ontological entity used to represent formal formalisms, theories, models of computation, and methodological approaches"@en ;
                  rdfs:label "Formal entity"@en .


###  http://www.softlang.org/ontologies/tbox#PropertyEntity
tbox:PropertyEntity rdf:type owl:Class .


###  http://www.softlang.org/ontologies/tbox#SubjectArea
tbox:SubjectArea rdf:type owl:Class .


###  http://www.softlang.org/ontologies/tbox#TechnologicalSpace
tbox:TechnologicalSpace rdf:type owl:Class .


#################################################################
#    Individuals
#################################################################

###  http://www.softlang.org/ontologies/ae#ProgramArtifact
ae:ProgramArtifact rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#FM
ce:FM rdf:type owl:NamedIndividual ,
               tbox:ConceptualEntity ,
               tbox:SubjectArea ;
      foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Formal_methods> ;
      rdfs:comment "area concerned with mathematically rigorous methods for specification, development, and verification"@en ;
      rdfs:label "Formal Methods"@en .


###  http://www.softlang.org/ontologies/ce#PLT
ce:PLT rdf:type owl:NamedIndividual ,
                tbox:ConceptualEntity ,
                tbox:SubjectArea ;
       foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Programming_language_theory> ;
       rdfs:comment "area concerned with the formal study of programming languages and their properties"@en ;
       rdfs:label "Programming Language Theory"@en .


###  http://www.softlang.org/ontologies/ce#Programware
ce:Programware rdf:type owl:NamedIndividual ,
                        tbox:ConceptualEntity ,
                        tbox:TechnologicalSpace ;
               tbox:hasArtifact ae:ProgramArtifact ;
               tbox:hasTool te:Compiler ,
                            te:Interpreter ,
                            te:StaticAnalyzer ;
               rdfs:comment "technological space centered on programs, programming languages, compilation, interpretation, and program analysis"@en ;
               rdfs:label "Programware"@en .


###  http://www.softlang.org/ontologies/ce#SLE
ce:SLE rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#TCS
ce:TCS rdf:type owl:NamedIndividual ,
                tbox:ConceptualEntity ,
                tbox:SubjectArea ;
       foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Theoretical_computer_science> ;
       rdfs:comment "area concerned with the mathematical and theoretical foundations of computer science"@en ;
       rdfs:label "Theoretical Computer Science"@en .


###  http://www.softlang.org/ontologies/fe#AbstractSyntaxDefinitionApproach
fe:AbstractSyntaxDefinitionApproach rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/fe#DenotationalSemantics
fe:DenotationalSemantics rdf:type owl:NamedIndividual ,
                                  fe:FormalSemanticsApproach ,
                                  tbox:FormalEntity ;
                         tbox:hasArea ce:PLT ,
                                      ce:SLE ;
                         tbox:hasSpace ce:Programware ;
                         tbox:serves fe:MetaprogrammingApproach ,
                                     fe:ProgramTransformation ;
                         tbox:uses fe:AbstractSyntaxDefinitionApproach ,
                                   fe:DomainTheory ,
                                   fe:LambdaCalculus ;
                         foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Denotational_semantics> ;
                         rdfs:comment "formal-semantics approach based on mathematical denotations"@en ;
                         rdfs:label "Denotational semantics"@en .


###  http://www.softlang.org/ontologies/fe#DomainTheory
fe:DomainTheory rdf:type owl:NamedIndividual ,
                         tbox:FormalEntity ;
                tbox:hasArea ce:FM ,
                             ce:PLT ,
                             ce:TCS ;
                tbox:hasSpace ce:Programware ;
                foaf:page <https://en.wikipedia.org/wiki/Domain_theory> .


###  http://www.softlang.org/ontologies/fe#LambdaCalculus
fe:LambdaCalculus rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/fe#MetaprogrammingApproach
fe:MetaprogrammingApproach rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/fe#ProgramTransformation
fe:ProgramTransformation rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/fe#Theory
fe:Theory rdf:type owl:NamedIndividual ,
                   tbox:FormalEntity ;
          tbox:hasArea ce:FM ,
                       ce:PLT ,
                       ce:TCS ;
          tbox:hasSpace ce:Programware ;
          foaf:page <https://en.wikipedia.org/wiki/Theory> .


###  http://www.softlang.org/ontologies/tbox#Entity
tbox:Entity rdf:type owl:NamedIndividual ;
            foaf:page <https://en.wikipedia.org/wiki/Knowledge_representation_and_reasoning> .


###  http://www.softlang.org/ontologies/tbox#SubjectArea
tbox:SubjectArea rdf:type owl:NamedIndividual ,
                          tbox:ConceptualEntity .


###  http://www.softlang.org/ontologies/tbox#TechnologicalSpace
tbox:TechnologicalSpace rdf:type owl:NamedIndividual ,
                                 tbox:ConceptualEntity .


###  http://www.softlang.org/ontologies/tbox#hasArea
tbox:hasArea rdf:type owl:NamedIndividual ,
                      tbox:PropertyEntity .


###  http://www.softlang.org/ontologies/tbox#hasArtifact
tbox:hasArtifact rdf:type owl:NamedIndividual ,
                          tbox:PropertyEntity .


###  http://www.softlang.org/ontologies/tbox#hasSpace
tbox:hasSpace rdf:type owl:NamedIndividual ,
                       tbox:PropertyEntity .


###  http://www.softlang.org/ontologies/tbox#hasTool
tbox:hasTool rdf:type owl:NamedIndividual ,
                      tbox:PropertyEntity .


###  http://www.softlang.org/ontologies/tbox#metamodelingPolicy
tbox:metamodelingPolicy rdf:type owl:NamedIndividual ,
                                 tbox:PropertyEntity ;
                        foaf:page <https://en.wikipedia.org/wiki/Guideline> .


###  http://www.softlang.org/ontologies/tbox#serves
tbox:serves rdf:type owl:NamedIndividual ,
                     tbox:PropertyEntity .


###  http://www.softlang.org/ontologies/tbox#uses
tbox:uses rdf:type owl:NamedIndividual ,
                   tbox:PropertyEntity .


###  http://www.softlang.org/ontologies/te#Compiler
te:Compiler rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/te#Interpreter
te:Interpreter rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/te#StaticAnalyzer
te:StaticAnalyzer rdf:type owl:NamedIndividual .


###  https://en.wikipedia.org/wiki/Denotational_semantics
<https://en.wikipedia.org/wiki/Denotational_semantics> rdf:type owl:NamedIndividual .


###  https://en.wikipedia.org/wiki/Domain_theory
<https://en.wikipedia.org/wiki/Domain_theory> rdf:type owl:NamedIndividual .


###  https://en.wikipedia.org/wiki/Formal_methods
<https://en.wikipedia.org/wiki/Formal_methods> rdf:type owl:NamedIndividual .


###  https://en.wikipedia.org/wiki/Guideline
<https://en.wikipedia.org/wiki/Guideline> rdf:type owl:NamedIndividual .


###  https://en.wikipedia.org/wiki/Knowledge_representation_and_reasoning
<https://en.wikipedia.org/wiki/Knowledge_representation_and_reasoning> rdf:type owl:NamedIndividual .


###  https://en.wikipedia.org/wiki/Programming_language_theory
<https://en.wikipedia.org/wiki/Programming_language_theory> rdf:type owl:NamedIndividual .


###  https://en.wikipedia.org/wiki/Theoretical_computer_science
<https://en.wikipedia.org/wiki/Theoretical_computer_science> rdf:type owl:NamedIndividual .


###  https://en.wikipedia.org/wiki/Theory
<https://en.wikipedia.org/wiki/Theory> rdf:type owl:NamedIndividual .


