tbox:CompositeConcept rdfs:comment "a language concept as a composite of other language concepts"@en ;
                      rdfs:label "Composite concept"@en ;
                      <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Category:Programming_language_concepts> .


tbox:EngineeringActivity rdfs:comment "Root class for software engineering activity types."@en ;
                         rdfs:label "Engineering activity"@en ;
                         <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Software_development_process> .


tbox:ImplementationMechanismConcept rdfs:comment "a more realization/implementation-oriented category of language concepts"@en ;
                                    rdfs:label "Implementation mechanism concept"@en ;
                                    <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Category:Programming_language_concepts> .


tbox:LanguageConcept rdfs:comment "concept associated with a language framework such as programming-language concepts"@en ;
                     rdfs:label "Language concept"@en ;
                     <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Category:Programming_language_concepts> .


tbox:LanguageConceptApplicability rdfs:comment "qualifier for how directly a language concept applies to a language"@en ;
                                  rdfs:label "Language concept applicability"@en ;
                                  <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Category:Programming_language_concepts> .


tbox:LanguageSupportAssertion rdfs:comment "reified assertion that a language supports a language concept, optionally qualified"@en ;
                              rdfs:label "Language support assertion"@en ;
                              <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Category:Programming_language_concepts> .


tbox:LanguageSupportKind rdfs:comment "kind of support that a language provides for a language concept"@en ;
                         rdfs:label "Language support kind"@en ;
                         <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Category:Programming_language_concepts> .


tbox:MethodologicalApproach rdfs:comment "class of formal entities that represent methodological orientations, techniques, or styles of treatment used in the study or engineering of software languages and related formalisms"@en ;
                            rdfs:label "Methodological approach"@en .


tbox:SoftwareArtifact rdfs:comment "Software artifact kind used to classify the characteristic artifacts of a technological space"@en ;
                      rdfs:label "Software artifact"@en .


tbox:SoftwareLanguage rdfs:comment "Concrete software languages (e.g., XML, SQL, OWL) are represented as individuals of this class. Language families are represented as subclasses. Artifact kinds capture the kinds of artifacts written in such languages."@en ;
                      rdfs:label "Software language"@en ;
                      <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Software_language> .


tbox:SoftwareTool rdfs:label "Software tool"@en ;
                  <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Programming_tool> .


tbox:SubjectArea rdfs:comment "research or application area relevant to the foundations of software languages and related disciplines"@en ;
                 rdfs:label "Subject area"@en .


tbox:TechnologicalSpace rdfs:comment "Technological spaces are families of related software-language technologies that share characteristic artifact kinds, metalanguages, tools, conformance relations, skills, and communities of practice. A technological space is not just a single language or formalism, but a working context in which artifacts are defined, manipulated, queried, transformed, validated, exchanged, and executed according to characteristic principles. This class represents such ecosystems."@en ;
                        rdfs:label "Technological space"@en .


tbox:assertedForConcept rdfs:comment "Relates a reified assertion about language concepts with the concept"@en ;
                        rdfs:label "Asserted for concept"@en ;
                        <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Category:Programming_language_concepts> .


tbox:assertedForLanguage rdfs:comment "Relates a reified assertion about language concepts with the language"@en ;
                         rdfs:label "Asserted for language"@en ;
                         <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Category:Programming_language_concepts> .


tbox:classifies rdfs:comment "Relates an artifact to another artifact in the generalized sense of metamodels classifying models"@en ;
                rdfs:label "classifies"@en ;
                <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Metamodeling> .


tbox:commentingPolicy rdfs:comment "Documents the ontology-wide expectation regarding commenting"@en ;
                      rdfs:label "Commenting policy"@en ;
                      <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Guideline> .


tbox:conformsTo rdfs:comment "Relates an artifact to another artifact in the generalized sense of models conforming to metamodels"@en ;
                rdfs:label "conforms to"@en ;
                <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Metamodeling> .


tbox:critique rdfs:comment "Describes the problem, concern, or critique expressed by an issue"@en ;
              rdfs:label "critique"@en ;
              <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Issue_tracking_system> .


tbox:defines rdfs:comment "Relates an artifact to a language in the sense of a definition (specification)"@en ;
             rdfs:label "defines"@en ;
             <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Programming_language_specification> .


tbox:elementOf rdfs:comment "Relates an artifact to a language in the set-theoretic sense"@en ;
               rdfs:label "element of"@en ;
               <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Membership_function_(mathematics)> .


tbox:extends rdfs:comment "Relates a software language to another software language that it extends or generalizes"@en ;
             rdfs:label "extends"@en ;
             <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/N/A> .


tbox:formattingPolicy rdfs:comment "Documents the ontology-wide expectation regarding formatting"@en ;
                      rdfs:label "Formatting policy"@en ;
                      <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Guideline> .


tbox:hasAffectedArtifact rdfs:comment "Relates an activity or a tool to an artifact kind that it typically affects (thereby complementing in- and output)"@en ;
                         rdfs:label "has affected artifact"@en ;
                         <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Artifact_(software_development)> .


tbox:hasApplicability rdfs:comment "Relates a reified assertion about language concepts with the applicability"@en ;
                      rdfs:label "Has applicability"@en ;
                      <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Category:Programming_language_concepts> .


tbox:hasArea rdfs:comment "Relates an entity to an important subject area of interest"@en ;
             rdfs:label "has area"@en ;
             <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Academic_discipline> .


tbox:hasArtifact rdfs:comment "Relates a technological space to a kind of artifact that it is concerned with"@en ;
                 rdfs:label "has artifact"@en ;
                 <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Artifact_(software_development)> .


tbox:hasBibTeX rdfs:comment "Relates an entity to the BibTeX key of a bibliographic entry that documents, discusses, or supports it"@en ;
               rdfs:label "has BibTeX"@en ;
               <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Annotated_bibliography> .


tbox:hasComponent rdfs:comment "Relates a composite language concept to a component"@en ;
                  rdfs:label "Has component"@en ;
                  <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Category:Programming_language_concepts> .


tbox:hasDominantForm rdfs:comment "Relates a language concept to a dominated form"@en ;
                     rdfs:label "Has dominant form"@en ;
                     <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Category:Programming_language_concepts> .


tbox:hasElement rdfs:comment "Relates a language to an artifact in the set-theoretic sense"@en ;
                rdfs:label "has element"@en ;
                <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Membership_function_(mathematics)> .


tbox:hasInputArtifact rdfs:comment "Relates an activity or a tool to an artifact kind that it typically requires or consumes as input"@en ;
                      rdfs:label "has input artifact"@en ;
                      <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Artifact_(software_development)> .


tbox:hasOutputArtifact rdfs:comment "Relates an activity or a tool to an artifact kind that it typically produces as output"@en ;
                       rdfs:label "has output artifact"@en ;
                       <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Artifact_(software_development)> .


tbox:hasPrimaryComponent rdfs:comment "Relates a composite language concept to a (primary) component"@en ;
                         rdfs:label "Has primary component"@en ;
                         <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Category:Programming_language_concepts> .


tbox:hasPrimaryMechanism rdfs:comment "Relates a reified assertion about language concepts with the primary mechanism for realization"@en ;
                         rdfs:label "Has primary mechanism"@en ;
                         <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Category:Programming_language_concepts> .


tbox:hasSecondaryComponent rdfs:comment "Relates a composite language concept to a (secondary) component"@en ;
                           rdfs:label "Has secondary component"@en ;
                           <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Category:Programming_language_concepts> .


tbox:hasSpace rdfs:comment "Relates an entity to a technological space to which it characteristically belongs"@en ;
              rdfs:label "has space"@en ;
              <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/N/A> .


tbox:hasSupportKind rdfs:comment "Relates a reified assertion about language concepts with the type of support"@en ;
                    rdfs:label "Has support kind"@en ;
                    <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Category:Programming_language_concepts> .


tbox:hasSupportingLanguage rdfs:comment "Relates a software engineering activity to a language kind that is characteristically used to perform or express the activity"@en ;
                           rdfs:label "has supporting language"@en ;
                           <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/N/A> .


tbox:hasSupportingTool rdfs:comment "Relates a software engineering activity to a tool kind that characteristically supports carrying out the activity"@en ;
                       rdfs:label "has supporting tool"@en ;
                       <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/N/A> .


tbox:hasTool rdfs:comment "Relates a technological space to a kind of tool that it is concerned with"@en ;
             rdfs:label "has tool"@en ;
             <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Programming_tool> .


tbox:isAreaOf rdfs:comment "Relates a subject area to an entity for which it is an important area of interest"@en ;
              rdfs:label "is area of"@en ;
              <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Academic_discipline> .


tbox:isArtifactOf rdfs:comment "Relates an artifact to its technological space"@en ;
                  rdfs:label "is artifact of"@en ;
                  <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Artifact_(software_development)> .


tbox:isDefinedBy rdfs:comment "Relates a language to an artifact in the sense of a definition (specification)"@en ;
                 rdfs:label "is defined by"@en ;
                 <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Programming_language_specification> .


tbox:isExtendedBy rdfs:comment "Relates a software language to another software language that extends or generalizes it"@en ;
                  rdfs:label "is extended by"@en ;
                  <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/N/A> .


tbox:isProcessedBy rdfs:comment "Relates an artifact entity to a tool entity that characteristically processes it"@en ;
                   rdfs:label "is processed by"@en ;
                   <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/N/A> .


tbox:isServedBy rdfs:comment "Relates a methodological approach to an entity that serves, realizes, supports, or instantiates it in an important way"@en ;
                rdfs:label "is served by"@en ;
                <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/N/A> .


tbox:isSpaceOf rdfs:comment "Relates a technological space to an entity that characteristically belongs to it"@en ;
               rdfs:label "is space of"@en ;
               <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/N/A> .


