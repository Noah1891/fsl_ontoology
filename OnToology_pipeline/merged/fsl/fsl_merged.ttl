] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( fe:ComputationalProblem
                fe:DataStructure
                fe:FormalObject
                fe:MathematicalStructure
                [ rdf:type owl:Class ;
                  owl:unionOf ( fe:FormalSystem
