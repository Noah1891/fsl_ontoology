                                 ] .


###  http://www.softlang.org/ontologies/le#MetamodelingLanguage
le:MetamodelingLanguage rdf:type owl:Class ;
                        rdfs:subClassOf le:Metalanguage .


###  http://www.softlang.org/ontologies/le#ModelTransformationLanguage
le:ModelTransformationLanguage rdf:type owl:Class ;
                               rdfs:subClassOf le:TransformationLanguage .


###  http://www.softlang.org/ontologies/le#ModelingLanguage
le:ModelingLanguage rdf:type owl:Class ;
                    rdfs:subClassOf tbox:SoftwareLanguage ;
                    owl:disjointWith [ rdf:type owl:Class ;
                                       owl:unionOf ( le:ConstraintLanguage
                                                     le:DataDefinitionLanguage
                                                     le:DataManipulationLanguage
                                                     le:QueryLanguage
                                                     le:TransformationLanguage
                                                   )
                                     ] .


###  http://www.softlang.org/ontologies/le#OntologyLanguage
le:OntologyLanguage rdf:type owl:Class ;
                    rdfs:subClassOf tbox:SoftwareLanguage ;
                    owl:disjointWith [ rdf:type owl:Class ;
                                       owl:unionOf ( le:ConstraintLanguage
                                                     le:DataDefinitionLanguage
                                                     le:DataManipulationLanguage
                                                     le:QueryLanguage
                                                     le:TransformationLanguage
                                                   )
                                     ] .


###  http://www.softlang.org/ontologies/le#ProofLanguage
le:ProofLanguage rdf:type owl:Class ;
                 rdfs:subClassOf tbox:SoftwareLanguage ;
                 owl:disjointWith [ rdf:type owl:Class ;
                                    owl:unionOf ( le:ConstraintLanguage
                                                  le:DataDefinitionLanguage
                                                  le:DataManipulationLanguage
                                                  le:QueryLanguage
                                                  le:TransformationLanguage
                                                )
                                  ] .


###  http://www.softlang.org/ontologies/le#PropertyGraphDataModelLanguage
le:PropertyGraphDataModelLanguage rdf:type owl:Class ;
                                  rdfs:subClassOf tbox:SoftwareLanguage .


###  http://www.softlang.org/ontologies/le#QueryLanguage
le:QueryLanguage rdf:type owl:Class ;
                 rdfs:subClassOf tbox:SoftwareLanguage .


###  http://www.softlang.org/ontologies/le#RelationalQueryLanguage
le:RelationalQueryLanguage rdf:type owl:Class ;
                           rdfs:subClassOf le:QueryLanguage .


###  http://www.softlang.org/ontologies/le#RequirementsSpecificationLanguage
le:RequirementsSpecificationLanguage rdf:type owl:Class ;
                                     rdfs:subClassOf tbox:SoftwareLanguage ;
                                     owl:disjointWith [ rdf:type owl:Class ;
                                                        owl:unionOf ( le:ConstraintLanguage
                                                                      le:DataDefinitionLanguage
                                                                      le:DataManipulationLanguage
                                                                      le:QueryLanguage
                                                                      le:TransformationLanguage
                                                                    )
                                                      ] .


###  http://www.softlang.org/ontologies/le#RuleLanguage
le:RuleLanguage rdf:type owl:Class ;
                rdfs:subClassOf tbox:SoftwareLanguage ;
                owl:disjointWith [ rdf:type owl:Class ;
                                   owl:unionOf ( le:ConstraintLanguage
                                                 le:DataDefinitionLanguage
                                                 le:DataManipulationLanguage
                                                 le:QueryLanguage
                                                 le:TransformationLanguage
                                               )
                                 ] .


###  http://www.softlang.org/ontologies/le#SchemaLanguage
le:SchemaLanguage rdf:type owl:Class ;
                  rdfs:subClassOf tbox:SoftwareLanguage ;
                  owl:disjointWith [ rdf:type owl:Class ;
                                     owl:unionOf ( le:ConstraintLanguage
                                                   le:DataDefinitionLanguage
                                                   le:DataManipulationLanguage
                                                   le:QueryLanguage
                                                   le:TransformationLanguage
                                                 )
                                   ] .


###  http://www.softlang.org/ontologies/le#SemanticDataModelLanguage
le:SemanticDataModelLanguage rdf:type owl:Class ;
                             rdfs:subClassOf tbox:SoftwareLanguage ;
                             owl:disjointWith [ rdf:type owl:Class ;
                                                owl:unionOf ( le:ConstraintLanguage
                                                              le:DataDefinitionLanguage
                                                              le:DataManipulationLanguage
                                                              le:QueryLanguage
                                                              le:TransformationLanguage
                                                            )
                                              ] .


###  http://www.softlang.org/ontologies/le#SemanticQueryLanguage
le:SemanticQueryLanguage rdf:type owl:Class ;
                         rdfs:subClassOf le:QueryLanguage .


###  http://www.softlang.org/ontologies/le#TransformationLanguage
le:TransformationLanguage rdf:type owl:Class ;
                          rdfs:subClassOf tbox:SoftwareLanguage .


###  http://www.softlang.org/ontologies/le#XMLQueryLanguage
le:XMLQueryLanguage rdf:type owl:Class ;
                    rdfs:subClassOf le:QueryLanguage .


###  http://www.softlang.org/ontologies/le#XMLSchemaLanguage
le:XMLSchemaLanguage rdf:type owl:Class ;
                     rdfs:subClassOf le:SchemaLanguage .


###  http://www.softlang.org/ontologies/pe#ProgrammingLanguage
pe:ProgrammingLanguage rdf:type owl:Class ;
                       rdfs:subClassOf tbox:SoftwareLanguage ;
                       owl:disjointWith [ rdf:type owl:Class ;
                                          owl:unionOf ( le:ConstraintLanguage
                                                        le:DataDefinitionLanguage
                                                        le:DataManipulationLanguage
                                                        le:QueryLanguage
                                                        le:TransformationLanguage
                                                      )
                                        ] .


###  http://www.softlang.org/ontologies/tbox#ArtifactEntity
tbox:ArtifactEntity rdf:type owl:Class ;
                    rdfs:subClassOf tbox:Entity ;
                    tbox:metamodelingPolicy "All non-immediate subclasses must also be of this type."@en ;
                    rdfs:comment "Ontological entity used to represent software artifacts, artifact families, and artifact-related instances"@en ;
                    rdfs:label "Artifact entity"@en .


###  http://www.softlang.org/ontologies/tbox#Assertion
tbox:Assertion rdf:type owl:Class ;
               rdfs:subClassOf tbox:ConceptualEntity ;
               rdfs:comment "Reified assertion entity used for qualified statements in language-related modules"@en ;
               rdfs:label "Assertion"@en ;
               <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> <https://en.wikipedia.org/wiki/Reification_(knowledge_representation)> .


###  http://www.softlang.org/ontologies/tbox#CompositeConcept
tbox:CompositeConcept rdf:type owl:Class ;
                      rdfs:subClassOf tbox:LanguageConcept .


###  http://www.softlang.org/ontologies/tbox#ConceptualEntity
tbox:ConceptualEntity rdf:type owl:Class ;
                      rdfs:subClassOf tbox:Entity ;
                      tbox:metamodelingPolicy "All non-immediate subclasses must also be of this type."@en ;
                      rdfs:comment "Contextual concepts for other entity types (foundations, languages, tools, and artifacts)"@en ;
                      rdfs:label "Conceptual entity"@en .


###  http://www.softlang.org/ontologies/tbox#EngineeringActivity
tbox:EngineeringActivity rdf:type owl:Class ;
                         rdfs:subClassOf tbox:ConceptualEntity .


###  http://www.softlang.org/ontologies/tbox#Entity
tbox:Entity rdf:type owl:Class ;
            rdfs:subClassOf [ rdf:type owl:Class ;
                              owl:unionOf ( [ rdf:type owl:Restriction ;
                                              owl:onProperty <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> ;
                                              owl:someValuesFrom <http://xmlns.com/foaf/0.1/Document>
                                            ]
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty <http://xmlns.com/foaf/0.1/page> ;
                                              owl:someValuesFrom <http://xmlns.com/foaf/0.1/Document>
                                            ]
                                          )
                            ] ;
            rdfs:comment "Top-level category for entities represented in this ontology. Entities should be linked to at least one descriptive document via foaf:isPrimaryTopicOf or foaf:page."@en ;
            rdfs:label "Entity"@en ;
            <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Knowledge_representation_and_reasoning> .


###  http://www.softlang.org/ontologies/tbox#FormalEntity
tbox:FormalEntity rdf:type owl:Class ;
                  rdfs:subClassOf tbox:Entity ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty tbox:hasArea ;
                                    owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onClass tbox:SubjectArea
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty tbox:hasSpace ;
                                    owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onClass tbox:TechnologicalSpace
                                  ] ;
                  tbox:metamodelingPolicy "All non-immediate subclasses must also be of this type."@en ;
                  rdfs:comment "Ontological entity used to represent formal formalisms, theories, models of computation, and methodological approaches"@en ;
                  rdfs:label "Formal entity"@en .


###  http://www.softlang.org/ontologies/tbox#ImplementationMechanismConcept
tbox:ImplementationMechanismConcept rdf:type owl:Class ;
                                    rdfs:subClassOf tbox:LanguageConcept .


###  http://www.softlang.org/ontologies/tbox#IssueEntity
tbox:IssueEntity rdf:type owl:Class ;
                 rdfs:subClassOf tbox:Entity ;
                 rdfs:comment "Entity for representing review issues, critiques, and proposed resolutions concerning resources, predicates, or fully specified assertions in the ontology"@en ;
                 rdfs:label "Issue entity"@en ;
                 <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Issue_tracking_system> .


###  http://www.softlang.org/ontologies/tbox#LanguageConcept
tbox:LanguageConcept rdf:type owl:Class ;
                     rdfs:subClassOf tbox:ConceptualEntity .


###  http://www.softlang.org/ontologies/tbox#LanguageConceptApplicability
tbox:LanguageConceptApplicability rdf:type owl:Class ;
                                  rdfs:subClassOf tbox:ConceptualEntity .


###  http://www.softlang.org/ontologies/tbox#LanguageEntity
tbox:LanguageEntity rdf:type owl:Class ;
                    rdfs:subClassOf tbox:Entity ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty tbox:hasArea ;
                                      owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                      owl:onClass tbox:SubjectArea
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty tbox:hasSpace ;
                                      owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                      owl:onClass tbox:TechnologicalSpace
                                    ] ;
                    tbox:metamodelingPolicy "All non-immediate subclasses must also be of this type."@en ;
                    rdfs:comment "Ontological entity used to represent software languages, language families, and language-related instances"@en ;
                    rdfs:label "Language entity"@en .


###  http://www.softlang.org/ontologies/tbox#LanguageSupportAssertion
tbox:LanguageSupportAssertion rdf:type owl:Class ;
                              rdfs:subClassOf tbox:Assertion .


###  http://www.softlang.org/ontologies/tbox#LanguageSupportKind
tbox:LanguageSupportKind rdf:type owl:Class ;
                         rdfs:subClassOf tbox:ConceptualEntity .


###  http://www.softlang.org/ontologies/tbox#MethodologicalApproach
tbox:MethodologicalApproach rdf:type owl:Class ;
                            rdfs:subClassOf tbox:FormalEntity .


###  http://www.softlang.org/ontologies/tbox#PropertyEntity
tbox:PropertyEntity rdf:type owl:Class ;
                    rdfs:subClassOf tbox:Entity ;
                    rdfs:comment "Ontological entity used to represent property declarations that participate in relations like other modeled entities"@en ;
                    rdfs:label "Property entity"@en .


###  http://www.softlang.org/ontologies/tbox#SoftwareArtifact
tbox:SoftwareArtifact rdf:type owl:Class ;
                      rdfs:subClassOf tbox:ArtifactEntity .


###  http://www.softlang.org/ontologies/tbox#SoftwareLanguage
tbox:SoftwareLanguage rdf:type owl:Class ;
                      rdfs:subClassOf tbox:LanguageEntity .


###  http://www.softlang.org/ontologies/tbox#SoftwareTool
tbox:SoftwareTool rdf:type owl:Class ;
                  rdfs:subClassOf tbox:ToolEntity .


###  http://www.softlang.org/ontologies/tbox#SubjectArea
tbox:SubjectArea rdf:type owl:Class ;
                 rdfs:subClassOf tbox:ConceptualEntity .


###  http://www.softlang.org/ontologies/tbox#TechnologicalSpace
tbox:TechnologicalSpace rdf:type owl:Class ;
                        rdfs:subClassOf tbox:ConceptualEntity .


###  http://www.softlang.org/ontologies/tbox#ToolEntity
tbox:ToolEntity rdf:type owl:Class ;
                rdfs:subClassOf tbox:Entity ;
                tbox:metamodelingPolicy "All non-immediate subclasses must also be of this type."@en ;
                rdfs:comment "Ontological entity used to represent software tools, tool families, and tool-related instances"@en ;
                rdfs:label "Tool entity"@en .


###  http://www.softlang.org/ontologies/te#APIWorkbench
te:APIWorkbench rdf:type owl:Class ;
                rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#BuildTool
te:BuildTool rdf:type owl:Class ;
             rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#Compiler
te:Compiler rdf:type owl:Class ;
            rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#ConfigurationTool
te:ConfigurationTool rdf:type owl:Class ;
                     rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#Database
te:Database rdf:type owl:Class ;
            rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#GrammarAnalyzer
te:GrammarAnalyzer rdf:type owl:Class ;
                   rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#GrammarTransformationEngine
te:GrammarTransformationEngine rdf:type owl:Class ;
                               rdfs:subClassOf te:TransformationEngine .


###  http://www.softlang.org/ontologies/te#GraphDatabase
te:GraphDatabase rdf:type owl:Class ;
                 rdfs:subClassOf te:Database .


###  http://www.softlang.org/ontologies/te#GraphDatabaseManagementSystem
te:GraphDatabaseManagementSystem rdf:type owl:Class ;
                                 rdfs:subClassOf te:GraphDatabase ,
                                                 te:QueryProcessor .


###  http://www.softlang.org/ontologies/te#Interpreter
te:Interpreter rdf:type owl:Class ;
               rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#JSONProcessor
te:JSONProcessor rdf:type owl:Class ;
                 rdfs:subClassOf tbox:SoftwareTool ;
                 owl:disjointWith te:XMLProcessor .


###  http://www.softlang.org/ontologies/te#LogicProgrammingSystem
te:LogicProgrammingSystem rdf:type owl:Class ;
                          rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#MarkupProcessor
te:MarkupProcessor rdf:type owl:Class ;
                   rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#ModelTransformationEngine
te:ModelTransformationEngine rdf:type owl:Class ;
                             rdfs:subClassOf te:TransformationEngine .


###  http://www.softlang.org/ontologies/te#ModelValidator
te:ModelValidator rdf:type owl:Class ;
                  rdfs:subClassOf te:Validator .


###  http://www.softlang.org/ontologies/te#ModelingWorkbench
te:ModelingWorkbench rdf:type owl:Class ;
                     rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#OntologyEditor
te:OntologyEditor rdf:type owl:Class ;
                  rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#ParserGenerator
te:ParserGenerator rdf:type owl:Class ;
                   rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#ProofAssistant
te:ProofAssistant rdf:type owl:Class ;
                  rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#QueryProcessor
te:QueryProcessor rdf:type owl:Class ;
                  rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#Reasoner
te:Reasoner rdf:type owl:Class ;
            rdfs:subClassOf tbox:SoftwareTool ,
                            te:SemanticReasoner .


###  http://www.softlang.org/ontologies/te#RefactoringTool
te:RefactoringTool rdf:type owl:Class ;
                   rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#RelationalDatabaseManagementSystem
te:RelationalDatabaseManagementSystem rdf:type owl:Class ;
                                      rdfs:subClassOf te:QueryProcessor ,
                                                      te:Validator .


###  http://www.softlang.org/ontologies/te#RequirementsTool
te:RequirementsTool rdf:type owl:Class ;
                    rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#RuleEngine
te:RuleEngine rdf:type owl:Class ;
              rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#SemanticReasoner
te:SemanticReasoner rdf:type owl:Class ;
                    rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#StaticAnalyzer
te:StaticAnalyzer rdf:type owl:Class ;
                  rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#TransformationEngine
te:TransformationEngine rdf:type owl:Class ;
                        rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#TripleStore
te:TripleStore rdf:type owl:Class ;
               rdfs:subClassOf te:QueryProcessor .


###  http://www.softlang.org/ontologies/te#Validator
te:Validator rdf:type owl:Class ;
             rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#XMLProcessor
te:XMLProcessor rdf:type owl:Class ;
                rdfs:subClassOf tbox:SoftwareTool .


###  http://xmlns.com/foaf/0.1/Document
<http://xmlns.com/foaf/0.1/Document> rdf:type owl:Class .


#################################################################
#    Individuals
#################################################################

###  http://www.softlang.org/ontologies/ae#APIDescriptionArtifact
ae:APIDescriptionArtifact rdf:type owl:NamedIndividual ,
                                   tbox:ArtifactEntity ;
                          tbox:elementOf le:InterfaceDescriptionLanguage .


###  http://www.softlang.org/ontologies/ae#BuildScriptArtifact
ae:BuildScriptArtifact rdf:type owl:NamedIndividual ,
                                tbox:ArtifactEntity ;
                       tbox:elementOf le:BuildScriptingLanguage ;
                       <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Build_automation> .


###  http://www.softlang.org/ontologies/ae#ConfigurationArtifact
ae:ConfigurationArtifact rdf:type owl:NamedIndividual ,
                                  tbox:ArtifactEntity ;
                         tbox:elementOf le:ConfigurationLanguage ;
                         <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Configuration_file> .


###  http://www.softlang.org/ontologies/ae#GrammarArtifact
ae:GrammarArtifact rdf:type owl:NamedIndividual ,
                            tbox:ArtifactEntity ;
                   tbox:conformsTo ae:GrammarOfGrammarsArtifact ;
                   tbox:elementOf le:GrammarMetalanguage .


###  http://www.softlang.org/ontologies/ae#GrammarOfGrammarsArtifact
ae:GrammarOfGrammarsArtifact rdf:type owl:NamedIndividual ,
                                      tbox:ArtifactEntity ;
                             tbox:defines le:GrammarMetalanguage ;
                             tbox:elementOf le:GrammarMetalanguage .


###  http://www.softlang.org/ontologies/ae#GraphQueryArtifact
ae:GraphQueryArtifact rdf:type owl:NamedIndividual ,
                               tbox:ArtifactEntity ;
                      tbox:elementOf le:GraphQueryLanguage .


###  http://www.softlang.org/ontologies/ae#JSONDocumentArtifact
ae:JSONDocumentArtifact rdf:type owl:NamedIndividual ,
                                 tbox:ArtifactEntity ;
                        tbox:conformsTo ae:JSONSchemaArtifact ;
                        tbox:elementOf le:JSON .


###  http://www.softlang.org/ontologies/ae#JSONSchemaArtifact
ae:JSONSchemaArtifact rdf:type owl:NamedIndividual ,
                               tbox:ArtifactEntity ;
                      tbox:classifies ae:JSONDocumentArtifact ;
                      tbox:elementOf le:JSONSchemaLanguage .


###  http://www.softlang.org/ontologies/ae#LogicProgramArtifact
ae:LogicProgramArtifact rdf:type owl:NamedIndividual ,
                                 tbox:ArtifactEntity ;
                        tbox:elementOf pe:ProgrammingLanguage .


###  http://www.softlang.org/ontologies/ae#MarkupArtifact
ae:MarkupArtifact rdf:type owl:NamedIndividual ,
                           tbox:ArtifactEntity ;
                  tbox:elementOf le:MarkupLanguage .


###  http://www.softlang.org/ontologies/ae#MegamodelArtifact
ae:MegamodelArtifact rdf:type owl:NamedIndividual ,
                              tbox:ArtifactEntity ;
                     tbox:elementOf le:MegamodelingLanguage ;
                     tbox:hasBibTeX "FavreLaemmelVaranovich2012LinguisticArchitecture" ,
                                    "FavreNguyen2004MegamodelEvolution" .


###  http://www.softlang.org/ontologies/ae#MetamodelArtifact
ae:MetamodelArtifact rdf:type owl:NamedIndividual ,
                              tbox:ArtifactEntity ;
                     tbox:elementOf le:MetamodelingLanguage .


###  http://www.softlang.org/ontologies/ae#ModelArtifact
ae:ModelArtifact rdf:type owl:NamedIndividual ,
                          tbox:ArtifactEntity ;
                 tbox:conformsTo ae:MetamodelArtifact ;
                 tbox:elementOf le:ModelingLanguage .


###  http://www.softlang.org/ontologies/ae#OntologyArtifact
ae:OntologyArtifact rdf:type owl:NamedIndividual ,
                             tbox:ArtifactEntity ;
                    tbox:classifies ae:RDFGraphArtifact ;
                    tbox:elementOf le:OntologyLanguage .


###  http://www.softlang.org/ontologies/ae#ProgramArtifact
ae:ProgramArtifact rdf:type owl:NamedIndividual ,
                            tbox:ArtifactEntity ;
                   tbox:elementOf pe:ProgrammingLanguage .


###  http://www.softlang.org/ontologies/ae#ProofArtifact
ae:ProofArtifact rdf:type owl:NamedIndividual ,
                          tbox:ArtifactEntity ;
                 tbox:elementOf le:ProofLanguage .


###  http://www.softlang.org/ontologies/ae#PropertyGraphArtifact
ae:PropertyGraphArtifact rdf:type owl:NamedIndividual ,
                                  tbox:ArtifactEntity ;
                         tbox:elementOf le:PropertyGraphDataModelLanguage .


###  http://www.softlang.org/ontologies/ae#RDFGraphArtifact
ae:RDFGraphArtifact rdf:type owl:NamedIndividual ,
                             tbox:ArtifactEntity ;
                    tbox:conformsTo ae:ShapeArtifact ;
                    tbox:elementOf le:RDF .


###  http://www.softlang.org/ontologies/ae#RelationalDataArtifact
ae:RelationalDataArtifact rdf:type owl:NamedIndividual ,
                                   tbox:ArtifactEntity ;
                          tbox:conformsTo ae:RelationalSchemaArtifact ;
                          tbox:elementOf le:SQLDML .


###  http://www.softlang.org/ontologies/ae#RelationalQueryArtifact
ae:RelationalQueryArtifact rdf:type owl:NamedIndividual ,
                                    tbox:ArtifactEntity ;
                           tbox:elementOf le:SQLQuery .


###  http://www.softlang.org/ontologies/ae#RelationalSchemaArtifact
ae:RelationalSchemaArtifact rdf:type owl:NamedIndividual ,
                                     tbox:ArtifactEntity ;
                            tbox:classifies ae:RelationalDataArtifact ;
                            tbox:elementOf le:SQLDDL .


###  http://www.softlang.org/ontologies/ae#RequirementsArtifact
ae:RequirementsArtifact rdf:type owl:NamedIndividual ,
                                 tbox:ArtifactEntity ;
                        tbox:elementOf le:RequirementsSpecificationLanguage ;
                        <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Software_requirements_specification> .


###  http://www.softlang.org/ontologies/ae#RuleArtifact
ae:RuleArtifact rdf:type owl:NamedIndividual ,
                         tbox:ArtifactEntity ;
                tbox:elementOf le:RuleLanguage .


###  http://www.softlang.org/ontologies/ae#SemanticDataArtifact
ae:SemanticDataArtifact rdf:type owl:NamedIndividual ,
                                 tbox:ArtifactEntity .


###  http://www.softlang.org/ontologies/ae#ShapeArtifact
ae:ShapeArtifact rdf:type owl:NamedIndividual ,
                          tbox:ArtifactEntity ;
                 tbox:classifies ae:RDFGraphArtifact ;
                 tbox:elementOf le:ConstraintLanguage .


###  http://www.softlang.org/ontologies/ae#XMLDocumentArtifact
ae:XMLDocumentArtifact rdf:type owl:NamedIndividual ,
                                tbox:ArtifactEntity ;
                       tbox:conformsTo ae:XMLSchemaArtifact ;
                       tbox:elementOf le:XML .


###  http://www.softlang.org/ontologies/ae#XMLSchemaArtifact
ae:XMLSchemaArtifact rdf:type owl:NamedIndividual ,
                              tbox:ArtifactEntity ;
                     tbox:classifies ae:XMLDocumentArtifact ;
                     tbox:elementOf le:XMLSchemaLanguage .


###  http://www.softlang.org/ontologies/ce#APIDesign
ce:APIDesign rdf:type owl:NamedIndividual ,
                      tbox:ConceptualEntity ;
             tbox:hasOutputArtifact ae:APIDescriptionArtifact ;
             tbox:hasSupportingLanguage le:InterfaceDescriptionLanguage ;
             tbox:hasSupportingTool te:APIWorkbench ;
             tbox:uses fe:SoftwareDesignApproach ;
             <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/API> .


###  http://www.softlang.org/ontologies/ce#APIware
ce:APIware rdf:type owl:NamedIndividual ,
                    tbox:ConceptualEntity ,
                    tbox:TechnologicalSpace ;
           tbox:hasArtifact ae:APIDescriptionArtifact ;
           tbox:hasTool te:APIWorkbench ,
                        te:TransformationEngine ,
                        te:Validator ;
           rdfs:comment "technological space centered on interface descriptions, service contracts, API documentation, and contract-oriented tooling"@en ;
           rdfs:label "APIware"@en .


###  http://www.softlang.org/ontologies/ce#Abstraction
ce:Abstraction rdf:type owl:NamedIndividual ,
                        ce:AbstractionConcept ,
