###  http://www.softlang.org/ontologies/pe#Ada
:Ada rdf:type owl:NamedIndividual ,
              :ProgrammingLanguage ,
              tbox:LanguageEntity ;
     tbox:hasArea ce:PLT ,
                  ce:SE ,
                  ce:SLE ;
     tbox:hasSpace ce:Programware ;
     tbox:nativelySupports ce:DataAbstraction ,
                           ce:Exceptions ,
                           ce:ImperativeParadigm ,
                           ce:ProceduralAbstraction ,
                           ce:SharedMemoryConcurrency ,
                           ce:StaticTyping ,
                           ce:StrongTyping ,
                           ce:TaskParallelism ;
     foaf:isPrimaryTopicOf <https://dbpedia.org/resource/Ada_(programming_language)> ;
     foaf:page <https://en.wikipedia.org/wiki/Ada_(programming_language)> ;
     rdfs:comment "statically typed language with strong support for reliability and concurrency"@en ;
     rdfs:label "Ada"@en .


###  http://www.softlang.org/ontologies/pe#Assembly_Language
:Assembly_Language rdf:type owl:NamedIndividual ,
                            :ProgrammingLanguage ,
                            tbox:LanguageEntity ;
                   tbox:hasArea ce:PLT ,
                                ce:SE ,
                                ce:SLE ;
                   tbox:hasSpace ce:Programware ;
                   tbox:nativelySupports ce:Branching ,
                                         ce:ImperativeParadigm ,
                                         ce:Iteration ,
                                         ce:Sequencing ;
                   foaf:isPrimaryTopicOf <https://dbpedia.org/resource/Assembly_language> ;
                   foaf:page <https://en.wikipedia.org/wiki/Assembly_language> ;
                   rdfs:comment "low-level language family closely reflecting machine instruction sets"@en ;
                   rdfs:label "Assembly language"@en .


###  http://www.softlang.org/ontologies/pe#C
:C rdf:type owl:NamedIndividual ,
            :ProgrammingLanguage ,
            tbox:LanguageEntity ;
   tbox:hasArea ce:PLT ,
                ce:SE ,
                ce:SLE ;
   tbox:hasSpace ce:Programware ;
   tbox:nativelySupports ce:Branching ,
                         ce:ImperativeParadigm ,
                         ce:Iteration ,
                         ce:MutableData ,
                         ce:PrimitiveValues ,
                         ce:ProceduralAbstraction ,
                         ce:Records ,
                         ce:Recursion ,
                         ce:ReferenceSemantics ,
                         ce:ReferencesAndPointers ,
                         ce:Sequencing ,
                         ce:StaticTyping ;
   foaf:isPrimaryTopicOf <https://dbpedia.org/resource/C_(programming_language)> ;
   foaf:page <https://en.wikipedia.org/wiki/C_(programming_language)> ;
   rdfs:comment "procedural systems programming language with low-level control and widespread influence"@en ;
   rdfs:label "C"@en .


