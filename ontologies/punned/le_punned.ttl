ce:Programware rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#ProofConcept
ce:ProofConcept rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#Proofware
ce:Proofware rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#PureComputation
ce:PureComputation rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#QueryConcept
ce:QueryConcept rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#Recursion
ce:Recursion rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#Ruleware
ce:Ruleware rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#SE
ce:SE rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#SLE
ce:SLE rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#SQLware
ce:SQLware rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#SchemaConcept
ce:SchemaConcept rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#StaticTyping
ce:StaticTyping rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#StrongTyping
ce:StrongTyping rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#TCS
ce:TCS rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#TransformationConcept
ce:TransformationConcept rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#Tuples
ce:Tuples rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#XMLware
ce:XMLware rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/fe#ConcreteSyntaxDefinitionApproach
fe:ConcreteSyntaxDefinitionApproach rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/le#ATL
:ATL rdf:type owl:NamedIndividual ,
              :ModelTransformationLanguage ,
              tbox:LanguageEntity ;
     tbox:hasArea ce:MDE ,
                  ce:SE ,
                  ce:SLE ;
     tbox:hasSpace ce:Modelware ;
     tbox:supports ce:Abstraction ,
                   ce:DataAbstraction ,
                   ce:ModelingConcept ,
                   ce:TransformationConcept ;
     foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/ATLAS_Transformation_Language> ;
     rdfs:label "ATL"@en .


###  http://www.softlang.org/ontologies/le#BNF
:BNF rdf:type owl:NamedIndividual ,
              :GrammarMetalanguage ,
              tbox:LanguageEntity ;
     tbox:hasArea ce:CC ,
                  ce:SLE ,
                  ce:TCS ;
     tbox:hasSpace ce:Grammarware ;
     tbox:supports ce:GrammarConcept ,
                   ce:Recursion ;
     foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Backus%E2%80%93Naur_form> ;
     rdfs:comment "grammar metalanguage for expressing context-free grammars"@en ;
     rdfs:label "BNF"@en .


###  http://www.softlang.org/ontologies/le#BackusNaurForm
:BackusNaurForm rdf:type owl:NamedIndividual ,
                         :GrammarMetalanguage ,
                         tbox:LanguageEntity ;
                tbox:hasArea ce:CC ,
                             ce:SLE ;
                tbox:hasSpace ce:Grammarware ;
                tbox:serves fe:ConcreteSyntaxDefinitionApproach ;
                tbox:supports ce:GrammarConcept ,
                              ce:Recursion ;
                foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Backus%E2%80%93Naur_form> ;
                rdfs:comment "metalanguage for expressing context-free grammars"@en ;
                rdfs:label "Backus-Naur form"@en .


###  http://www.softlang.org/ontologies/le#BuildScriptingLanguage
:BuildScriptingLanguage rdf:type owl:NamedIndividual ,
                                 tbox:LanguageEntity ;
                        tbox:hasArea ce:SE ,
                                     ce:SLE ;
                        tbox:hasSpace ce:Programware ;
                        foaf:page <https://en.wikipedia.org/wiki/Build_automation> .


###  http://www.softlang.org/ontologies/le#ConfigurationLanguage
:ConfigurationLanguage rdf:type owl:NamedIndividual ,
                                tbox:LanguageEntity ;
                       tbox:hasArea ce:SE ,
                                    ce:SLE ;
                       tbox:hasSpace ce:Markupware ;
                       foaf:page <https://en.wikipedia.org/wiki/Configuration_file> .


###  http://www.softlang.org/ontologies/le#ConstraintLanguage
:ConstraintLanguage rdf:type owl:NamedIndividual ,
                             tbox:LanguageEntity ;
                    tbox:hasArea ce:KR ,
                                 ce:SE ,
                                 ce:SLE ;
                    tbox:hasSpace ce:Ontoware ;
                    tbox:supports ce:ConstraintConcept ,
                                  ce:DeclarativeParadigm ,
                                  ce:LogicParadigm ,
                                  ce:PureComputation ,
                                  ce:StaticTyping ,
                                  ce:StrongTyping ;
                    foaf:page <https://en.wikipedia.org/wiki/Constraint_programming> .


###  http://www.softlang.org/ontologies/le#Coq
:Coq rdf:type owl:NamedIndividual ,
              :ProofLanguage ,
              tbox:LanguageEntity ;
     tbox:hasArea ce:FM ,
                  ce:KR ,
                  ce:SLE ;
     tbox:hasSpace ce:Proofware ;
     foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Coq> ;
     rdfs:label "Coq"@en .


###  http://www.softlang.org/ontologies/le#Cypher
:Cypher rdf:type owl:NamedIndividual ,
                 :GraphQueryLanguage ,
                 tbox:LanguageEntity ;
        tbox:hasArea ce:SE ,
                     ce:SLE ;
        tbox:hasSpace ce:Graphware ;
        foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Cypher_(query_language)> ;
        rdfs:label "Cypher"@en .


###  http://www.softlang.org/ontologies/le#DataDefinitionLanguage
:DataDefinitionLanguage rdf:type owl:NamedIndividual ,
                                 tbox:LanguageEntity ;
                        tbox:hasArea ce:SE ,
                                     ce:SLE ;
                        tbox:hasSpace ce:SQLware ;
                        foaf:page <https://en.wikipedia.org/wiki/Data_definition_language> .


###  http://www.softlang.org/ontologies/le#DataManipulationLanguage
:DataManipulationLanguage rdf:type owl:NamedIndividual ,
                                   tbox:LanguageEntity ;
                          tbox:hasArea ce:SE ,
                                       ce:SLE ;
                          tbox:hasSpace ce:SQLware ;
                          foaf:page <https://en.wikipedia.org/wiki/Data_manipulation_language> .


###  http://www.softlang.org/ontologies/le#DocumentTransformationLanguage
:DocumentTransformationLanguage rdf:type owl:NamedIndividual ,
                                         tbox:LanguageEntity ;
                                tbox:hasArea ce:SE ,
                                             ce:SLE ;
                                tbox:hasSpace ce:JSONware ,
                                              ce:XMLware ;
                                foaf:page <https://en.wikipedia.org/wiki/XSLT> .


###  http://www.softlang.org/ontologies/le#EBNF
:EBNF rdf:type owl:NamedIndividual ,
               :GrammarMetalanguage ,
               tbox:LanguageEntity ;
      tbox:extends :BNF ;
      tbox:hasArea ce:CC ,
                   ce:SLE ,
                   ce:TCS ;
      tbox:hasSpace ce:Grammarware ;
      tbox:supports ce:GrammarConcept ,
                    ce:Recursion ;
      foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Extended_Backus%E2%80%93Naur_form> ;
      rdfs:comment "extended grammar metalanguage for expressing grammars"@en ;
      rdfs:label "EBNF"@en .


###  http://www.softlang.org/ontologies/le#Ecore
:Ecore rdf:type owl:NamedIndividual ,
                :MetamodelingLanguage ,
                tbox:LanguageEntity ;
       tbox:hasArea ce:MDE ,
                    ce:SE ,
                    ce:SLE ;
       tbox:hasSpace ce:Modelware ;
       tbox:supports ce:Abstraction ,
                     ce:DataAbstraction ,
                     ce:ModelingConcept ,
                     ce:Namespaces ,
                     ce:Packages ,
                     ce:TransformationConcept ;
       foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Eclipse_Modeling_Framework> ;
       rdfs:label "Ecore"@en .


###  http://www.softlang.org/ontologies/le#ExtendedBackusNaurForm
:ExtendedBackusNaurForm rdf:type owl:NamedIndividual ,
                                 :GrammarMetalanguage ,
                                 tbox:LanguageEntity ;
                        tbox:extends :BackusNaurForm ;
                        tbox:hasArea ce:CC ,
                                     ce:SLE ;
                        tbox:hasSpace ce:Grammarware ;
                        tbox:serves fe:ConcreteSyntaxDefinitionApproach ;
                        tbox:supports ce:GrammarConcept ,
                                      ce:Recursion ;
                        foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Extended_Backus%E2%80%93Naur_form> ;
                        rdfs:comment "metalanguage for grammar notation"@en ;
                        rdfs:label "Extended Backus-Naur form"@en .


###  http://www.softlang.org/ontologies/le#GrammarMetalanguage
:GrammarMetalanguage rdf:type owl:NamedIndividual ,
                              tbox:LanguageEntity ;
                     tbox:hasArea ce:CC ,
                                  ce:SLE ;
                     tbox:hasSpace ce:Grammarware ;
                     tbox:supports ce:GrammarConcept ,
                                   ce:Recursion ;
                     foaf:page <https://en.wikipedia.org/wiki/Metasyntax> .


###  http://www.softlang.org/ontologies/le#GrammarTransformationLanguage
:GrammarTransformationLanguage rdf:type owl:NamedIndividual ,
                                        tbox:LanguageEntity ;
                               tbox:hasArea ce:CC ,
                                            ce:SLE ;
                               tbox:hasSpace ce:Grammarware ;
                               foaf:page <https://en.wikipedia.org/wiki/Program_transformation> .


###  http://www.softlang.org/ontologies/le#GraphQLSchema
:GraphQLSchema rdf:type owl:NamedIndividual ,
                        :InterfaceDescriptionLanguage ,
                        tbox:LanguageEntity ;
               tbox:hasArea ce:SE ,
                            ce:SLE ;
               tbox:hasSpace ce:APIware ;
               foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/GraphQL> ;
               rdfs:label "GraphQL schema language"@en .


###  http://www.softlang.org/ontologies/le#GraphQueryLanguage
:GraphQueryLanguage rdf:type owl:NamedIndividual ,
                             tbox:LanguageEntity ;
                    tbox:hasArea ce:SE ,
                                 ce:SLE ;
                    tbox:hasSpace ce:Graphware ;
                    foaf:page <https://en.wikipedia.org/wiki/Graph_query_language> .


###  http://www.softlang.org/ontologies/le#GraphQueryLanguageStandard
:GraphQueryLanguageStandard rdf:type owl:NamedIndividual ,
                                     :QueryLanguage ,
                                     tbox:LanguageEntity ;
                            tbox:hasArea ce:SE ,
                                         ce:SLE ;
                            tbox:hasSpace ce:Graphware ;
                            foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Graph_Query_Language> ;
                            rdfs:comment "standardized query language for property graphs"@en ;
                            rdfs:label "Graph Query Language"@en .


###  http://www.softlang.org/ontologies/le#Gremlin
:Gremlin rdf:type owl:NamedIndividual ,
                  :QueryLanguage ,
                  tbox:LanguageEntity ;
         tbox:hasArea ce:SE ,
                      ce:SLE ;
         tbox:hasSpace ce:Graphware ;
         foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Gremlin_(query_language)> ;
         rdfs:comment "graph traversal and query language for graph databases and graph processors"@en ;
         rdfs:label "Gremlin"@en .


###  http://www.softlang.org/ontologies/le#HTML
:HTML rdf:type owl:NamedIndividual ,
               :MarkupLanguage ,
               tbox:LanguageEntity ;
      tbox:hasArea ce:SE ,
                   ce:SLE ;
      tbox:hasSpace ce:Markupware ;
      foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/HTML> ;
      rdfs:label "HTML"@en .


###  http://www.softlang.org/ontologies/le#InterfaceDescriptionLanguage
:InterfaceDescriptionLanguage rdf:type owl:NamedIndividual ,
                                       tbox:LanguageEntity ;
                              tbox:hasArea ce:SE ,
                                           ce:SLE ;
                              tbox:hasSpace ce:APIware ;
                              foaf:page <https://en.wikipedia.org/wiki/Interface_description_language> .


###  http://www.softlang.org/ontologies/le#JSON
:JSON rdf:type owl:NamedIndividual ,
               tbox:LanguageEntity ,
               tbox:SoftwareLanguage ;
