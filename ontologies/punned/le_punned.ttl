@prefix : <http://www.softlang.org/ontologies/le#> .
@prefix ce: <http://www.softlang.org/ontologies/ce#> .
@prefix fe: <http://www.softlang.org/ontologies/fe#> .
@prefix pe: <http://www.softlang.org/ontologies/pe#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix tbox: <http://www.softlang.org/ontologies/tbox#> .
@base <http://www.softlang.org/ontologies/le> .

<http://www.softlang.org/ontologies/le> rdf:type owl:Ontology ;
                                         owl:imports <http://www.softlang.org/ontologies/tbox> ;
                                         tbox:commentingPolicy "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
                                         tbox:formattingPolicy "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
                                         tbox:linkingPolicy "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
                                         tbox:metamodelingPolicy "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
                                         rdfs:comment "Programming languages are maintained in the pe module; this module keeps non-programming software languages and broad language-kind taxonomies."@en ,
                                                      "Sub-ontology / ABox for software languages"@en .

#################################################################
#    Classes
#################################################################

###  http://www.softlang.org/ontologies/le#BuildScriptingLanguage
:BuildScriptingLanguage rdf:type owl:Class ;
                        rdfs:subClassOf tbox:SoftwareLanguage ;
                        owl:disjointWith [ rdf:type owl:Class ;
                                           owl:unionOf ( :ConstraintLanguage
                                                         :DataDefinitionLanguage
                                                         :DataManipulationLanguage
                                                         :QueryLanguage
                                                         :TransformationLanguage
                                                       )
                                         ] .


###  http://www.softlang.org/ontologies/le#ConfigurationLanguage
:ConfigurationLanguage rdf:type owl:Class ;
                       rdfs:subClassOf tbox:SoftwareLanguage ;
                       owl:disjointWith [ rdf:type owl:Class ;
                                          owl:unionOf ( :ConstraintLanguage
                                                        :DataDefinitionLanguage
                                                        :DataManipulationLanguage
                                                        :QueryLanguage
                                                        :TransformationLanguage
                                                      )
                                        ] .


###  http://www.softlang.org/ontologies/le#ConstraintLanguage
:ConstraintLanguage rdf:type owl:Class ;
                    rdfs:subClassOf tbox:SoftwareLanguage .


###  http://www.softlang.org/ontologies/le#DataDefinitionLanguage
:DataDefinitionLanguage rdf:type owl:Class ;
                        rdfs:subClassOf tbox:SoftwareLanguage .


###  http://www.softlang.org/ontologies/le#DataManipulationLanguage
:DataManipulationLanguage rdf:type owl:Class ;
                          rdfs:subClassOf tbox:SoftwareLanguage .


###  http://www.softlang.org/ontologies/le#DocumentTransformationLanguage
:DocumentTransformationLanguage rdf:type owl:Class ;
                                rdfs:subClassOf :TransformationLanguage .


###  http://www.softlang.org/ontologies/le#GrammarMetalanguage
:GrammarMetalanguage rdf:type owl:Class ;
                     rdfs:subClassOf :Metalanguage .


###  http://www.softlang.org/ontologies/le#GrammarTransformationLanguage
:GrammarTransformationLanguage rdf:type owl:Class ;
                               rdfs:subClassOf :TransformationLanguage .


###  http://www.softlang.org/ontologies/le#GraphQueryLanguage
:GraphQueryLanguage rdf:type owl:Class ;
                    rdfs:subClassOf :QueryLanguage .


###  http://www.softlang.org/ontologies/le#InterfaceDescriptionLanguage
:InterfaceDescriptionLanguage rdf:type owl:Class ;
                              rdfs:subClassOf tbox:SoftwareLanguage ;
                              owl:disjointWith [ rdf:type owl:Class ;
                                                 owl:unionOf ( :ConstraintLanguage
                                                               :DataDefinitionLanguage
                                                               :DataManipulationLanguage
                                                               :QueryLanguage
                                                               :TransformationLanguage
                                                             )
                                               ] .


###  http://www.softlang.org/ontologies/le#JSONQueryLanguage
:JSONQueryLanguage rdf:type owl:Class ;
                   rdfs:subClassOf :QueryLanguage .


###  http://www.softlang.org/ontologies/le#JSONSchemaLanguage
:JSONSchemaLanguage rdf:type owl:Class ;
                    rdfs:subClassOf :SchemaLanguage .


###  http://www.softlang.org/ontologies/le#MappingLanguage
:MappingLanguage rdf:type owl:Class ;
                 rdfs:subClassOf tbox:SoftwareLanguage ;
                 owl:disjointWith [ rdf:type owl:Class ;
                                    owl:unionOf ( :ConstraintLanguage
                                                  :DataDefinitionLanguage
                                                  :DataManipulationLanguage
                                                  :QueryLanguage
                                                  :TransformationLanguage
                                                )
                                  ] .


###  http://www.softlang.org/ontologies/le#MarkupLanguage
:MarkupLanguage rdf:type owl:Class ;
                rdfs:subClassOf tbox:SoftwareLanguage ;
                owl:disjointWith [ rdf:type owl:Class ;
                                   owl:unionOf ( :ConstraintLanguage
                                                 :DataDefinitionLanguage
                                                 :DataManipulationLanguage
                                                 :QueryLanguage
                                                 :TransformationLanguage
                                               )
                                 ] .


###  http://www.softlang.org/ontologies/le#MegamodelingLanguage
:MegamodelingLanguage rdf:type owl:Class ;
                      rdfs:subClassOf :ModelingLanguage .


###  http://www.softlang.org/ontologies/le#Metalanguage
:Metalanguage rdf:type owl:Class ;
              rdfs:subClassOf tbox:SoftwareLanguage ;
              owl:disjointWith [ rdf:type owl:Class ;
                                 owl:unionOf ( :ConstraintLanguage
                                               :DataDefinitionLanguage
                                               :DataManipulationLanguage
                                               :QueryLanguage
                                               :TransformationLanguage
                                             )
                               ] .


###  http://www.softlang.org/ontologies/le#MetamodelingLanguage
:MetamodelingLanguage rdf:type owl:Class ;
                      rdfs:subClassOf :Metalanguage .


###  http://www.softlang.org/ontologies/le#ModelTransformationLanguage
:ModelTransformationLanguage rdf:type owl:Class ;
                             rdfs:subClassOf :TransformationLanguage .


###  http://www.softlang.org/ontologies/le#ModelingLanguage
:ModelingLanguage rdf:type owl:Class ;
                  rdfs:subClassOf tbox:SoftwareLanguage ;
                  owl:disjointWith [ rdf:type owl:Class ;
                                     owl:unionOf ( :ConstraintLanguage
                                                   :DataDefinitionLanguage
                                                   :DataManipulationLanguage
                                                   :QueryLanguage
                                                   :TransformationLanguage
                                                 )
                                   ] .


###  http://www.softlang.org/ontologies/le#OntologyLanguage
:OntologyLanguage rdf:type owl:Class ;
                  rdfs:subClassOf tbox:SoftwareLanguage ;
                  owl:disjointWith [ rdf:type owl:Class ;
                                     owl:unionOf ( :ConstraintLanguage
                                                   :DataDefinitionLanguage
                                                   :DataManipulationLanguage
                                                   :QueryLanguage
                                                   :TransformationLanguage
                                                 )
                                   ] .


###  http://www.softlang.org/ontologies/le#ProofLanguage
:ProofLanguage rdf:type owl:Class ;
               rdfs:subClassOf tbox:SoftwareLanguage ;
               owl:disjointWith [ rdf:type owl:Class ;
                                  owl:unionOf ( :ConstraintLanguage
                                                :DataDefinitionLanguage
                                                :DataManipulationLanguage
                                                :QueryLanguage
                                                :TransformationLanguage
                                              )
                                ] .


###  http://www.softlang.org/ontologies/le#PropertyGraphDataModelLanguage
:PropertyGraphDataModelLanguage rdf:type owl:Class ;
                                rdfs:subClassOf tbox:SoftwareLanguage .


###  http://www.softlang.org/ontologies/le#QueryLanguage
:QueryLanguage rdf:type owl:Class ;
               rdfs:subClassOf tbox:SoftwareLanguage .


###  http://www.softlang.org/ontologies/le#RelationalQueryLanguage
:RelationalQueryLanguage rdf:type owl:Class ;
                         rdfs:subClassOf :QueryLanguage .


###  http://www.softlang.org/ontologies/le#RequirementsSpecificationLanguage
:RequirementsSpecificationLanguage rdf:type owl:Class ;
                                   rdfs:subClassOf tbox:SoftwareLanguage ;
                                   owl:disjointWith [ rdf:type owl:Class ;
                                                      owl:unionOf ( :ConstraintLanguage
                                                                    :DataDefinitionLanguage
                                                                    :DataManipulationLanguage
                                                                    :QueryLanguage
                                                                    :TransformationLanguage
                                                                  )
                                                    ] .


###  http://www.softlang.org/ontologies/le#RuleLanguage
:RuleLanguage rdf:type owl:Class ;
              rdfs:subClassOf tbox:SoftwareLanguage ;
              owl:disjointWith [ rdf:type owl:Class ;
                                 owl:unionOf ( :ConstraintLanguage
                                               :DataDefinitionLanguage
                                               :DataManipulationLanguage
                                               :QueryLanguage
                                               :TransformationLanguage
                                             )
                               ] .


###  http://www.softlang.org/ontologies/le#SchemaLanguage
:SchemaLanguage rdf:type owl:Class ;
                rdfs:subClassOf tbox:SoftwareLanguage ;
                owl:disjointWith [ rdf:type owl:Class ;
                                   owl:unionOf ( :ConstraintLanguage
                                                 :DataDefinitionLanguage
                                                 :DataManipulationLanguage
                                                 :QueryLanguage
                                                 :TransformationLanguage
                                               )
                                 ] .


###  http://www.softlang.org/ontologies/le#SemanticDataModelLanguage
:SemanticDataModelLanguage rdf:type owl:Class ;
                           rdfs:subClassOf tbox:SoftwareLanguage ;
                           owl:disjointWith [ rdf:type owl:Class ;
                                              owl:unionOf ( :ConstraintLanguage
                                                            :DataDefinitionLanguage
                                                            :DataManipulationLanguage
                                                            :QueryLanguage
                                                            :TransformationLanguage
                                                          )
                                            ] .


###  http://www.softlang.org/ontologies/le#SemanticQueryLanguage
:SemanticQueryLanguage rdf:type owl:Class ;
                       rdfs:subClassOf :QueryLanguage .


###  http://www.softlang.org/ontologies/le#TransformationLanguage
:TransformationLanguage rdf:type owl:Class ;
                        rdfs:subClassOf tbox:SoftwareLanguage .


###  http://www.softlang.org/ontologies/le#XMLQueryLanguage
:XMLQueryLanguage rdf:type owl:Class ;
                  rdfs:subClassOf :QueryLanguage .


###  http://www.softlang.org/ontologies/le#XMLSchemaLanguage
:XMLSchemaLanguage rdf:type owl:Class ;
                   rdfs:subClassOf :SchemaLanguage .


###  http://www.softlang.org/ontologies/pe#ProgrammingLanguage
pe:ProgrammingLanguage rdf:type owl:Class ;
                       owl:disjointWith [ rdf:type owl:Class ;
                                          owl:unionOf ( :ConstraintLanguage
                                                        :DataDefinitionLanguage
                                                        :DataManipulationLanguage
                                                        :QueryLanguage
                                                        :TransformationLanguage
                                                      )
                                        ] .


