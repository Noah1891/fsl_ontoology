@prefix : <http://www.softlang.org/ontologies/te#> .
@prefix ae: <http://www.softlang.org/ontologies/ae#> .
@prefix ce: <http://www.softlang.org/ontologies/ce#> .
@prefix le: <http://www.softlang.org/ontologies/le#> .
@prefix pe: <http://www.softlang.org/ontologies/pe#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix tbox: <http://www.softlang.org/ontologies/tbox#> .
@base <http://www.softlang.org/ontologies/te> .

<http://www.softlang.org/ontologies/te> rdf:type owl:Ontology ;
                                         owl:imports <http://www.softlang.org/ontologies/tbox> ;
                                         tbox:commentingPolicy "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
                                         tbox:formattingPolicy "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
                                         tbox:linkingPolicy "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
                                         tbox:metamodelingPolicy "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
                                         rdfs:comment "Sub-ontology / ABox for software tools"@en .

#################################################################
#    Classes
#################################################################

###  http://www.softlang.org/ontologies/te#APIWorkbench
:APIWorkbench rdf:type owl:Class ;
              rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#BuildTool
:BuildTool rdf:type owl:Class ;
           rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#Compiler
:Compiler rdf:type owl:Class ;
          rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#ConfigurationTool
:ConfigurationTool rdf:type owl:Class ;
                   rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#Database
:Database rdf:type owl:Class ;
          rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#GrammarAnalyzer
:GrammarAnalyzer rdf:type owl:Class ;
                 rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#GrammarTransformationEngine
:GrammarTransformationEngine rdf:type owl:Class ;
                             rdfs:subClassOf :TransformationEngine .


###  http://www.softlang.org/ontologies/te#GraphDatabase
:GraphDatabase rdf:type owl:Class ;
               rdfs:subClassOf :Database .


###  http://www.softlang.org/ontologies/te#GraphDatabaseManagementSystem
:GraphDatabaseManagementSystem rdf:type owl:Class ;
                               rdfs:subClassOf :GraphDatabase ,
                                               :QueryProcessor .


###  http://www.softlang.org/ontologies/te#Interpreter
:Interpreter rdf:type owl:Class ;
             rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#JSONProcessor
:JSONProcessor rdf:type owl:Class ;
               rdfs:subClassOf tbox:SoftwareTool ;
               owl:disjointWith :XMLProcessor .


###  http://www.softlang.org/ontologies/te#LogicProgrammingSystem
:LogicProgrammingSystem rdf:type owl:Class ;
                        rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#MarkupProcessor
:MarkupProcessor rdf:type owl:Class ;
                 rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#ModelTransformationEngine
:ModelTransformationEngine rdf:type owl:Class ;
                           rdfs:subClassOf :TransformationEngine .


###  http://www.softlang.org/ontologies/te#ModelValidator
:ModelValidator rdf:type owl:Class ;
                rdfs:subClassOf :Validator .


###  http://www.softlang.org/ontologies/te#ModelingWorkbench
:ModelingWorkbench rdf:type owl:Class ;
                   rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#OntologyEditor
:OntologyEditor rdf:type owl:Class ;
                rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#ParserGenerator
:ParserGenerator rdf:type owl:Class ;
                 rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#ProofAssistant
:ProofAssistant rdf:type owl:Class ;
                rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#QueryProcessor
:QueryProcessor rdf:type owl:Class ;
                rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#Reasoner
:Reasoner rdf:type owl:Class ;
          rdfs:subClassOf tbox:SoftwareTool ,
                          :SemanticReasoner .


###  http://www.softlang.org/ontologies/te#RefactoringTool
:RefactoringTool rdf:type owl:Class ;
                 rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#RelationalDatabaseManagementSystem
:RelationalDatabaseManagementSystem rdf:type owl:Class ;
                                    rdfs:subClassOf :QueryProcessor ,
                                                    :Validator .


###  http://www.softlang.org/ontologies/te#RequirementsTool
:RequirementsTool rdf:type owl:Class ;
                  rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#RuleEngine
:RuleEngine rdf:type owl:Class ;
            rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#SemanticReasoner
:SemanticReasoner rdf:type owl:Class ;
                  rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#StaticAnalyzer
:StaticAnalyzer rdf:type owl:Class ;
                rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#TransformationEngine
:TransformationEngine rdf:type owl:Class ;
                      rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#TripleStore
:TripleStore rdf:type owl:Class ;
             rdfs:subClassOf :QueryProcessor .


###  http://www.softlang.org/ontologies/te#Validator
:Validator rdf:type owl:Class ;
           rdfs:subClassOf tbox:SoftwareTool .


###  http://www.softlang.org/ontologies/te#XMLProcessor
:XMLProcessor rdf:type owl:Class ;
              rdfs:subClassOf tbox:SoftwareTool .


