pe:ProgrammingLanguage rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/pe#Prolog
pe:Prolog rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/te#ANTLR
:ANTLR rdf:type owl:NamedIndividual ,
                tbox:ToolEntity ,
                :ParserGenerator ;
       foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/ANTLR> ;
       rdfs:comment "parser generator based on grammar notation with semantic and syntactic processing support"@en ;
       rdfs:label "ANTLR"@en .


###  http://www.softlang.org/ontologies/te#APIWorkbench
:APIWorkbench rdf:type owl:NamedIndividual ,
                       tbox:ToolEntity ;
              tbox:hasAffectedArtifact ae:APIDescriptionArtifact ;
              tbox:hasInputArtifact ae:APIDescriptionArtifact ;
              tbox:hasOutputArtifact ae:APIDescriptionArtifact ;
              tbox:processes ae:APIDescriptionArtifact ;
              tbox:targets le:InterfaceDescriptionLanguage .


###  http://www.softlang.org/ontologies/te#ATLTransformationEngine
:ATLTransformationEngine rdf:type owl:NamedIndividual ,
                                  tbox:ToolEntity ,
                                  :ModelTransformationEngine ;
                         foaf:page <https://eclipse.dev/atl/> ;
                         rdfs:comment "engine for executing ATL model transformations"@en ;
                         rdfs:label "ATL transformation engine"@en .


###  http://www.softlang.org/ontologies/te#Ansible
:Ansible rdf:type owl:NamedIndividual ,
                  tbox:ToolEntity ,
                  :ConfigurationTool ;
         foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Ansible_(software)> ;
         rdfs:comment "configuration automation tool commonly used with YAML-based configuration artifacts"@en ;
         rdfs:label "Ansible"@en .


###  http://www.softlang.org/ontologies/te#ApacheJena
:ApacheJena rdf:type owl:NamedIndividual ,
                     tbox:ToolEntity ,
                     :Reasoner ,
                     :TripleStore ;
            foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Apache_Jena> ;
            rdfs:comment "framework for RDF storage, SPARQL processing, and reasoning"@en ;
            rdfs:label "Apache Jena"@en .


###  http://www.softlang.org/ontologies/te#BaseX
:BaseX rdf:type owl:NamedIndividual ,
                tbox:ToolEntity ,
                :QueryProcessor ,
                :XMLProcessor ;
       foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/BaseX> ;
       rdfs:comment "XML database and XQuery processor"@en ;
       rdfs:label "BaseX"@en .


###  http://www.softlang.org/ontologies/te#Bison
:Bison rdf:type owl:NamedIndividual ,
                tbox:ToolEntity ,
                :ParserGenerator ;
       foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/GNU_Bison> ;
       rdfs:comment "parser generator for context-free grammars"@en ;
       rdfs:label "Bison"@en .


###  http://www.softlang.org/ontologies/te#BuildTool
:BuildTool rdf:type owl:NamedIndividual ,
                    tbox:ToolEntity ;
           tbox:hasInputArtifact ae:BuildScriptArtifact ,
                                 ae:ConfigurationArtifact ;
           tbox:targets le:BuildScriptingLanguage ,
                        le:ConfigurationLanguage ;
           foaf:page <https://en.wikipedia.org/wiki/Build_automation> .


###  http://www.softlang.org/ontologies/te#CPython
:CPython rdf:type owl:NamedIndividual ,
                  tbox:ToolEntity ,
                  :Interpreter ;
         foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/CPython> ;
         rdfs:comment "reference interpreter implementation of the Python programming language"@en ;
         rdfs:label "CPython"@en .


###  http://www.softlang.org/ontologies/te#Compiler
:Compiler rdf:type owl:NamedIndividual ,
                   tbox:ToolEntity ;
          tbox:hasInputArtifact ae:ProgramArtifact ;
          tbox:hasOutputArtifact ae:ProgramArtifact ;
          tbox:processes ae:ProgramArtifact ;
          tbox:targets pe:ProgrammingLanguage .


###  http://www.softlang.org/ontologies/te#ConfigurationTool
:ConfigurationTool rdf:type owl:NamedIndividual ,
                            tbox:ToolEntity ;
                   tbox:hasAffectedArtifact ae:ConfigurationArtifact ;
                   tbox:hasInputArtifact ae:ConfigurationArtifact ;
                   tbox:hasOutputArtifact ae:ConfigurationArtifact ;
                   tbox:targets le:ConfigurationLanguage ;
                   foaf:page <https://en.wikipedia.org/wiki/Configuration_management> .


###  http://www.softlang.org/ontologies/te#CoqProofAssistant
:CoqProofAssistant rdf:type owl:NamedIndividual ,
                            tbox:ToolEntity ,
                            :ProofAssistant ;
                   foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Coq> ;
                   rdfs:comment "proof assistant for interactive theorem proving based on dependent type theory"@en ;
                   rdfs:label "Coq proof assistant"@en .


###  http://www.softlang.org/ontologies/te#Database
:Database rdf:type owl:NamedIndividual ,
                   tbox:ToolEntity ;
          foaf:page <https://en.wikipedia.org/wiki/Database> .


###  http://www.softlang.org/ontologies/te#Drools
:Drools rdf:type owl:NamedIndividual ,
                 tbox:ToolEntity ,
                 :RuleEngine ;
        foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Drools> ;
        rdfs:comment "rule engine and business rule management system"@en ;
        rdfs:label "Drools"@en .


###  http://www.softlang.org/ontologies/te#EclipseIDE
:EclipseIDE rdf:type owl:NamedIndividual ,
                     tbox:ToolEntity ,
                     :RefactoringTool ;
            foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Eclipse_(software)> ;
            rdfs:comment "integrated development environment with refactoring support"@en ;
            rdfs:label "Eclipse IDE"@en .


###  http://www.softlang.org/ontologies/te#EclipseModelingFramework
:EclipseModelingFramework rdf:type owl:NamedIndividual ,
                                   tbox:ToolEntity ,
                                   :ModelingWorkbench ;
                          foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Eclipse_Modeling_Framework> ;
                          rdfs:comment "modeling workbench for Ecore-based models and metamodels"@en ;
                          rdfs:label "Eclipse Modeling Framework"@en .


###  http://www.softlang.org/ontologies/te#GCC
:GCC rdf:type owl:NamedIndividual ,
              tbox:ToolEntity ,
              :Compiler ;
     foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/GNU_Compiler_Collection> ;
     rdfs:comment "compiler collection for several programming languages"@en ;
     rdfs:label "GCC"@en .


###  http://www.softlang.org/ontologies/te#GNUMake
:GNUMake rdf:type owl:NamedIndividual ,
                  tbox:ToolEntity ,
                  :BuildTool ;
         foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/GNU_Make> ;
         rdfs:comment "build automation tool for executing Makefile-based build specifications"@en ;
         rdfs:label "GNU Make"@en .


###  http://www.softlang.org/ontologies/te#GrammarAnalyzer
:GrammarAnalyzer rdf:type owl:NamedIndividual ,
                          tbox:ToolEntity ;
                 tbox:processes ae:GrammarArtifact ;
                 tbox:targets le:GrammarMetalanguage .


###  http://www.softlang.org/ontologies/te#GrammarTransformationEngine
:GrammarTransformationEngine rdf:type owl:NamedIndividual ,
                                      tbox:ToolEntity ;
                             tbox:processes ae:GrammarArtifact ;
                             tbox:targets le:GrammarTransformationLanguage .


###  http://www.softlang.org/ontologies/te#GraphDB
:GraphDB rdf:type owl:NamedIndividual ,
                  tbox:ToolEntity ,
                  :Reasoner ,
                  :TripleStore ;
         foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/GraphDB> ;
         rdfs:comment "semantic graph database with RDF storage and reasoning support"@en ;
         rdfs:label "GraphDB"@en .


###  http://www.softlang.org/ontologies/te#GraphDatabase
:GraphDatabase rdf:type owl:NamedIndividual ,
                        tbox:ToolEntity ;
               tbox:hasSpace ce:Graphware ;
               foaf:page <https://en.wikipedia.org/wiki/Graph_database> .


###  http://www.softlang.org/ontologies/te#GraphDatabaseManagementSystem
:GraphDatabaseManagementSystem rdf:type owl:NamedIndividual ,
                                        tbox:ToolEntity ;
                               tbox:hasSpace ce:Graphware ;
                               tbox:processes ae:GraphQueryArtifact ,
                                              ae:PropertyGraphArtifact ;
                               tbox:targets le:GraphQueryLanguage ,
                                            le:PropertyGraphDataModelLanguage .


###  http://www.softlang.org/ontologies/te#IBMDOORS
:IBMDOORS rdf:type owl:NamedIndividual ,
                   tbox:ToolEntity ,
                   :RequirementsTool ;
          foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/IBM_DOORS> ;
          rdfs:comment "requirements management tool for capturing and organizing requirements artifacts"@en ;
          rdfs:label "IBM DOORS"@en .


###  http://www.softlang.org/ontologies/te#Interpreter
:Interpreter rdf:type owl:NamedIndividual ,
                      tbox:ToolEntity ;
             tbox:hasInputArtifact ae:ProgramArtifact ;
             tbox:processes ae:ProgramArtifact ;
             tbox:targets pe:ProgrammingLanguage .


###  http://www.softlang.org/ontologies/te#JSONProcessor
:JSONProcessor rdf:type owl:NamedIndividual ,
                        tbox:ToolEntity ;
               tbox:processes ae:JSONDocumentArtifact ,
                              ae:JSONSchemaArtifact ;
               tbox:targets le:JSON ,
                            le:JSONQueryLanguage ,
                            le:JSONSchemaLanguage .


###  http://www.softlang.org/ontologies/te#LeanProofAssistant
:LeanProofAssistant rdf:type owl:NamedIndividual ,
                             tbox:ToolEntity ,
                             :ProofAssistant ;
                    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Lean_(proof_assistant)> ;
                    rdfs:comment "proof assistant and programming environment for mechanized reasoning"@en ;
                    rdfs:label "Lean proof assistant"@en .


###  http://www.softlang.org/ontologies/te#LogicProgrammingSystem
:LogicProgrammingSystem rdf:type owl:NamedIndividual ,
                                 tbox:ToolEntity ;
                        tbox:processes ae:LogicProgramArtifact ;
                        tbox:targets pe:Datalog ,
                                     pe:Prolog .


###  http://www.softlang.org/ontologies/te#MarkupProcessor
:MarkupProcessor rdf:type owl:NamedIndividual ,
                          tbox:ToolEntity ;
                 tbox:processes ae:MarkupArtifact ;
                 tbox:targets le:MarkupLanguage .


###  http://www.softlang.org/ontologies/te#ModelTransformationEngine
:ModelTransformationEngine rdf:type owl:NamedIndividual ,
                                    tbox:ToolEntity ;
                           tbox:hasInputArtifact ae:MetamodelArtifact ,
                                                 ae:ModelArtifact ;
                           tbox:hasOutputArtifact ae:ModelArtifact ;
                           tbox:processes ae:MetamodelArtifact ,
                                          ae:ModelArtifact ;
                           tbox:targets le:ModelTransformationLanguage .


###  http://www.softlang.org/ontologies/te#ModelValidator
:ModelValidator rdf:type owl:NamedIndividual ,
                         tbox:ToolEntity ;
                tbox:processes ae:ModelArtifact ;
                tbox:targets le:ConstraintLanguage .


###  http://www.softlang.org/ontologies/te#ModelingWorkbench
:ModelingWorkbench rdf:type owl:NamedIndividual ,
                            tbox:ToolEntity ;
                   tbox:processes ae:MetamodelArtifact ,
                                  ae:ModelArtifact ;
                   tbox:targets le:MetamodelingLanguage ,
                                le:ModelingLanguage .


###  http://www.softlang.org/ontologies/te#Neo4j
:Neo4j rdf:type owl:NamedIndividual ,
                tbox:ToolEntity ,
                :GraphDatabaseManagementSystem ;
       foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Neo4j> ;
       rdfs:comment "graph database management system for property graphs"@en ;
       rdfs:label "Neo4j"@en .


###  http://www.softlang.org/ontologies/te#OntologyEditor
:OntologyEditor rdf:type owl:NamedIndividual ,
                         tbox:ToolEntity ;
                tbox:processes ae:OntologyArtifact ;
                tbox:targets le:OntologyLanguage .


