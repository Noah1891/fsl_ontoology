<https://en.wikipedia.org/wiki/Syntax_(programming_languages)> rdf:type owl:NamedIndividual .


#################################################################
#    Annotations
#################################################################

:AbstractRewritingSystem rdfs:label "Abstract rewriting system"@en .


:AnalyticGrammar rdfs:label "Analytic grammar"@en .


:ClassicalLambdaCalculus rdfs:label "Classical lambda calculus"@en .


:ComputationalProblem rdfs:comment "methodological approach centered on formally posed problems to be solved computationally"@en ,
                                   "methodological approach concerned with problem formulations addressed by computation"@en ;
                      rdfs:label "Computational problem"@en .


:DataManagementApproach rdfs:comment "methodological approach concerned with modeling, validating, and maintaining data"@en ,
                                     "methodological approach concerned with organizing, validating, governing, and manipulating data artifacts"@en ;
                        rdfs:label "Data management approach"@en .


:DataStructure rdfs:comment "methodological approach concerned with organizing and relating data in structures suited for computation and analysis"@en ,
                            "methodological approach concerned with the organization of data for efficient processing and access"@en ;
               rdfs:label "Data structure"@en .


:DescriptionLogic rdfs:label "Description logic"@en .


:DomainTheory rdfs:label "Domain theory"@en .


:FormalGrammar rdfs:label "Formal grammar"@en .


:FormalObject rdfs:comment "formal object used as a mathematically characterized syntactic or symbolic entity"@en ;
              rdfs:label "Formal object"@en .


:FormalSemanticsApproach rdfs:label "Formal semantics approach"@en .


:FormalSystem rdfs:comment "symbolic deductive formal system"@en ;
              rdfs:label "Formal system"@en .


:GenerativeGrammar rdfs:label "Generative grammar"@en .


:LambdaCalculus rdfs:label "Lambda calculus"@en .


:LambdaCube rdfs:label "Lambda cube"@en .


:MathematicalStructure rdfs:comment "methodological approach centered on mathematical structures used to organize formal reasoning"@en ;
                       rdfs:label "Mathematical structure"@en .


:MetaprogrammingApproach rdfs:label "Metaprogramming approach"@en .


:ModelOfComputation rdfs:comment "formal model for representing computation, execution, or state evolution"@en ;
                    rdfs:label "Model of computation"@en .


:ProcessCalculus rdfs:label "Process calculus"@en .


:ProgramLogic rdfs:label "Program logic"@en .


:SoftwareDesignApproach rdfs:comment "methodological approach concerned with the design of software structures, interfaces, and behavior"@en ,
                                     "methodological approach concerned with the design of software systems and their structures, interfaces, and contracts"@en ;
                        rdfs:label "Software design approach"@en .


:SyntaxDefinitionApproach rdfs:label "Syntax definition approach"@en .


:Theory rdfs:label "Theory"@en .


:TransitionSystem rdfs:label "Transition system"@en .


:TypeTheory rdfs:label "Type theory"@en .


#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :ComputationalProblem
                :DataStructure
                :FormalObject
                :MathematicalStructure
                [ rdf:type owl:Class ;
                  owl:unionOf ( :FormalSystem
                                :ModelOfComputation
                                :Theory
                              )
                ]
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :DescriptionLogic
                :FormalGrammar
                :LambdaCalculus
                :ProcessCalculus
                :ProgramLogic
              )
] .


