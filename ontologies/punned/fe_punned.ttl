@prefix : <http://www.softlang.org/ontologies/fe#> .
@prefix ce: <http://www.softlang.org/ontologies/ce#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix tbox: <http://www.softlang.org/ontologies/tbox#> .
@base <http://www.softlang.org/ontologies/fe> .

<http://www.softlang.org/ontologies/fe> rdf:type owl:Ontology ;
                                         owl:imports <http://www.softlang.org/ontologies/tbox> ;
                                         tbox:commentingPolicy "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
                                         tbox:formattingPolicy "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
                                         tbox:linkingPolicy "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
                                         tbox:metamodelingPolicy "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
                                         rdfs:comment "Sub-ontology / ABox for the formal entities"@en .

#################################################################
#    Classes
#################################################################

###  http://www.softlang.org/ontologies/fe#AbstractRewritingSystem
:AbstractRewritingSystem rdf:type owl:Class ;
                         rdfs:subClassOf :ModelOfComputation .


###  http://www.softlang.org/ontologies/fe#AnalyticGrammar
:AnalyticGrammar rdf:type owl:Class ;
                 rdfs:subClassOf :FormalGrammar .


###  http://www.softlang.org/ontologies/fe#ClassicalLambdaCalculus
:ClassicalLambdaCalculus rdf:type owl:Class ;
                         rdfs:subClassOf :LambdaCalculus .


###  http://www.softlang.org/ontologies/fe#ComputationalProblem
:ComputationalProblem rdf:type owl:Class ;
                      rdfs:subClassOf tbox:FormalEntity .


###  http://www.softlang.org/ontologies/fe#DataManagementApproach
:DataManagementApproach rdf:type owl:Class ;
                        rdfs:subClassOf tbox:MethodologicalApproach .


###  http://www.softlang.org/ontologies/fe#DataStructure
:DataStructure rdf:type owl:Class ;
               rdfs:subClassOf tbox:FormalEntity .


###  http://www.softlang.org/ontologies/fe#DescriptionLogic
:DescriptionLogic rdf:type owl:Class ;
                  rdfs:subClassOf :FormalSystem .


###  http://www.softlang.org/ontologies/fe#DomainTheory
:DomainTheory rdf:type owl:Class ;
              rdfs:subClassOf :Theory .


###  http://www.softlang.org/ontologies/fe#FormalGrammar
:FormalGrammar rdf:type owl:Class ;
               rdfs:subClassOf :FormalSystem .


###  http://www.softlang.org/ontologies/fe#FormalObject
:FormalObject rdf:type owl:Class ;
              rdfs:subClassOf tbox:FormalEntity .


###  http://www.softlang.org/ontologies/fe#FormalSemanticsApproach
:FormalSemanticsApproach rdf:type owl:Class ;
                         rdfs:subClassOf tbox:MethodologicalApproach .


###  http://www.softlang.org/ontologies/fe#FormalSystem
:FormalSystem rdf:type owl:Class ;
              rdfs:subClassOf tbox:FormalEntity .


###  http://www.softlang.org/ontologies/fe#GenerativeGrammar
:GenerativeGrammar rdf:type owl:Class ;
                   rdfs:subClassOf :FormalGrammar .


###  http://www.softlang.org/ontologies/fe#LambdaCalculus
:LambdaCalculus rdf:type owl:Class ;
                rdfs:subClassOf :FormalSystem .


###  http://www.softlang.org/ontologies/fe#LambdaCube
:LambdaCube rdf:type owl:Class ;
            rdfs:subClassOf :LambdaCalculus .


###  http://www.softlang.org/ontologies/fe#MathematicalStructure
:MathematicalStructure rdf:type owl:Class ;
                       rdfs:subClassOf tbox:FormalEntity .


###  http://www.softlang.org/ontologies/fe#MetaprogrammingApproach
:MetaprogrammingApproach rdf:type owl:Class ;
                         rdfs:subClassOf tbox:MethodologicalApproach .


###  http://www.softlang.org/ontologies/fe#ModelOfComputation
:ModelOfComputation rdf:type owl:Class ;
                    rdfs:subClassOf tbox:FormalEntity .


###  http://www.softlang.org/ontologies/fe#ProcessCalculus
:ProcessCalculus rdf:type owl:Class ;
                 rdfs:subClassOf :FormalSystem .


###  http://www.softlang.org/ontologies/fe#ProgramLogic
:ProgramLogic rdf:type owl:Class ;
              rdfs:subClassOf :FormalSystem .


###  http://www.softlang.org/ontologies/fe#SoftwareDesignApproach
:SoftwareDesignApproach rdf:type owl:Class ;
                        rdfs:subClassOf tbox:MethodologicalApproach .


###  http://www.softlang.org/ontologies/fe#SyntaxDefinitionApproach
:SyntaxDefinitionApproach rdf:type owl:Class ;
                          rdfs:subClassOf tbox:MethodologicalApproach .


###  http://www.softlang.org/ontologies/fe#Theory
:Theory rdf:type owl:Class ;
        rdfs:subClassOf tbox:FormalEntity .


###  http://www.softlang.org/ontologies/fe#TransitionSystem
:TransitionSystem rdf:type owl:Class ;
                  rdfs:subClassOf :ModelOfComputation .


###  http://www.softlang.org/ontologies/fe#TypeTheory
:TypeTheory rdf:type owl:Class ;
            rdfs:subClassOf :Theory .


#################################################################
#    Individuals
#################################################################

###  http://www.softlang.org/ontologies/ce#APIware
ce:APIware rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#CC
ce:CC rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#CL
ce:CL rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#FM
ce:FM rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#Grammarware
ce:Grammarware rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#Graphware
ce:Graphware rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#JSONware
ce:JSONware rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#KR
ce:KR rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#Logicware
ce:Logicware rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#MDE
ce:MDE rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#Markupware
ce:Markupware rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#Modelware
ce:Modelware rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#NLP
ce:NLP rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#Ontoware
ce:Ontoware rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#PLT
ce:PLT rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#Programware
ce:Programware rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#Proofware
ce:Proofware rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#Ruleware
ce:Ruleware rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#SE
ce:SE rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#SLE
ce:SLE rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#SQLware
ce:SQLware rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#TCS
ce:TCS rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/ce#XMLware
ce:XMLware rdf:type owl:NamedIndividual .


###  http://www.softlang.org/ontologies/fe#ALC
:ALC rdf:type owl:NamedIndividual ,
              :DescriptionLogic ,
              tbox:FormalEntity ;
     tbox:hasArea ce:KR ,
                  ce:TCS ;
     tbox:hasSpace ce:Ontoware ;
     foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Description_logic> ;
     rdfs:comment "basic attributional description logic with complement"@en ;
     rdfs:label "ALC"@en .


###  http://www.softlang.org/ontologies/fe#AbstractRewritingSystem
:AbstractRewritingSystem rdf:type owl:NamedIndividual ,
                                  tbox:FormalEntity ;
                         tbox:hasArea ce:PLT ,
                                      ce:SLE ,
                                      ce:TCS ;
                         tbox:hasSpace ce:Grammarware ;
                         foaf:page <https://en.wikipedia.org/wiki/Abstract_rewriting_system> .


###  http://www.softlang.org/ontologies/fe#AbstractSyntaxDefinitionApproach
:AbstractSyntaxDefinitionApproach rdf:type owl:NamedIndividual ,
                                           :SyntaxDefinitionApproach ,
                                           tbox:FormalEntity ;
                                  tbox:hasArea ce:CC ,
                                               ce:MDE ,
                                               ce:PLT ,
                                               ce:SLE ;
                                  tbox:hasSpace ce:Grammarware ,
                                                ce:JSONware ,
                                                ce:Modelware ,
                                                ce:XMLware ;
                                  foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Abstract_syntax> ;
                                  rdfs:comment "syntax-definition approach concerned with the structural representation of language constructs independently of concrete notation details"@en ;
                                  rdfs:label "Abstract syntax definition approach"@en .


###  http://www.softlang.org/ontologies/fe#AnalyticGrammar
:AnalyticGrammar rdf:type owl:NamedIndividual ,
                          tbox:FormalEntity ;
                 tbox:hasArea ce:CC ,
                              ce:SLE ,
                              ce:TCS ;
                 tbox:hasSpace ce:Grammarware ;
                 foaf:page <https://en.wikipedia.org/wiki/Formal_grammar#Analytic_grammars> .


###  http://www.softlang.org/ontologies/fe#AttributeGrammar
:AttributeGrammar rdf:type owl:NamedIndividual ,
                           :FormalGrammar ,
                           tbox:FormalEntity ;
                  tbox:extends :ContextFreeGrammar ;
                  tbox:hasArea ce:CC ,
                               ce:PLT ,
                               ce:SLE ;
                  tbox:hasSpace ce:Grammarware ;
                  tbox:serves :SyntaxDirectedTranslation ;
                  tbox:uses :ContextFreeGrammar ;
                  foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Attribute_grammar> ;
                  rdfs:comment "formal grammar with attributes and semantic rules"@en ;
                  rdfs:label "Attribute grammar"@en .


###  http://www.softlang.org/ontologies/fe#AxiomaticSemantics
:AxiomaticSemantics rdf:type owl:NamedIndividual ,
                             :FormalSemanticsApproach ,
                             tbox:FormalEntity ;
                    tbox:hasArea ce:FM ,
                                 ce:PLT ;
                    tbox:hasSpace ce:Programware ;
                    tbox:uses :AbstractSyntaxDefinitionApproach ,
                              :ProgramLogic ;
                    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Axiomatic_semantics> ;
                    rdfs:comment "formal-semantics approach based on axioms and logical proof principles"@en ;
                    rdfs:label "Axiomatic semantics"@en .


###  http://www.softlang.org/ontologies/fe#CalculusOfCommunicatingSystems
:CalculusOfCommunicatingSystems rdf:type owl:NamedIndividual ,
                                         :ProcessCalculus ,
                                         tbox:FormalEntity ;
                                tbox:hasArea ce:PLT ,
                                             ce:TCS ;
                                tbox:hasSpace ce:Programware ;
                                tbox:isSpecifiedBy :OperationalSemantics ;
                                foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Calculus_of_communicating_systems> ;
                                rdfs:comment "calculus for communicating concurrent systems"@en ;
                                rdfs:label "Calculus of communicating systems"@en .


###  http://www.softlang.org/ontologies/fe#CategoryTheory
:CategoryTheory rdf:type owl:NamedIndividual ,
                         :Theory ,
                         tbox:FormalEntity ;
                tbox:hasArea ce:FM ,
                             ce:MDE ,
                             ce:TCS ;
                tbox:hasSpace ce:Modelware ;
                foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Category_theory> ;
                rdfs:comment "mathematical theory of objects and morphisms used widely in abstract modeling and semantics"@en ;
                rdfs:label "Category theory"@en .


###  http://www.softlang.org/ontologies/fe#ClassicalLambdaCalculus
:ClassicalLambdaCalculus rdf:type owl:NamedIndividual ,
                                  tbox:FormalEntity ;
                         tbox:hasArea ce:PLT ,
                                      ce:TCS ;
                         tbox:hasSpace ce:Programware ;
                         foaf:page <https://en.wikipedia.org/wiki/Classical_logic#Lambda_calculi> .


###  http://www.softlang.org/ontologies/fe#CommunicatingSequentialProcesses
:CommunicatingSequentialProcesses rdf:type owl:NamedIndividual ,
                                           :ProcessCalculus ,
                                           tbox:FormalEntity ;
                                  tbox:hasArea ce:FM ,
                                               ce:PLT ,
                                               ce:TCS ;
                                  tbox:hasSpace ce:Programware ;
                                  tbox:isSpecifiedBy :OperationalSemantics ;
                                  foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Communicating_sequential_processes> ;
                                  rdfs:comment "process algebra for communication"@en ;
                                  rdfs:label "Communicating sequential processes"@en .


###  http://www.softlang.org/ontologies/fe#ComputationalProblem
:ComputationalProblem rdf:type owl:NamedIndividual ,
                               tbox:FormalEntity ;
                      tbox:hasArea ce:FM ,
                                   ce:SE ,
                                   ce:TCS ;
                      foaf:page <https://en.wikipedia.org/wiki/Computational_problem> .


###  http://www.softlang.org/ontologies/fe#ConcreteSyntaxDefinitionApproach
:ConcreteSyntaxDefinitionApproach rdf:type owl:NamedIndividual ,
                                           :SyntaxDefinitionApproach ,
                                           tbox:FormalEntity ;
                                  tbox:hasArea ce:CC ,
                                               ce:MDE ,
                                               ce:SLE ;
                                  tbox:hasSpace ce:Grammarware ,
                                                ce:Modelware ;
                                  rdfs:comment "syntax-definition approach concerned with the explicit surface representation of language constructs, including notation, delimiters, and other syntactically relevant details"@en ;
                                  rdfs:label "Concrete syntax definition approach"@en .


###  http://www.softlang.org/ontologies/fe#ConstraintSatisfactionProblem
:ConstraintSatisfactionProblem rdf:type owl:NamedIndividual ,
                                        :ComputationalProblem ,
                                        tbox:FormalEntity ;
                               tbox:hasArea ce:FM ,
                                            ce:SE ,
                                            ce:TCS ;
                               foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Constraint_satisfaction_problem> ;
                               rdfs:comment "computational problem of assigning values so that all specified constraints are satisfied"@en ,
                                            "computational problem of assigning values subject to constraints"@en ;
                               rdfs:label "Constraint satisfaction problem"@en .


###  http://www.softlang.org/ontologies/fe#ContextFreeGrammar
:ContextFreeGrammar rdf:type owl:NamedIndividual ,
                             :GenerativeGrammar ,
                             tbox:FormalEntity ;
                    tbox:hasArea ce:CC ,
                                 ce:SLE ,
                                 ce:TCS ;
                    tbox:hasSpace ce:Grammarware ;
                    tbox:serves :ConcreteSyntaxDefinitionApproach ;
                    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Context-free_grammar> ;
                    rdfs:comment "grammar with context-free productions"@en ;
                    rdfs:label "Context-free grammar"@en .


###  http://www.softlang.org/ontologies/fe#DataManagementApproach
:DataManagementApproach rdf:type owl:NamedIndividual ,
                                 tbox:FormalEntity ;
                        tbox:hasArea ce:SE ,
                                     ce:SLE ;
                        tbox:hasSpace ce:JSONware ,
                                      ce:Ontoware ,
                                      ce:SQLware ,
                                      ce:XMLware ;
                        foaf:page <https://en.wikipedia.org/wiki/Data_management> .


###  http://www.softlang.org/ontologies/fe#DataStructure
:DataStructure rdf:type owl:NamedIndividual ,
                        tbox:FormalEntity ;
               tbox:hasArea ce:SE ,
                            ce:SLE ;
               tbox:hasSpace ce:Graphware ;
               foaf:page <https://en.wikipedia.org/wiki/Data_structure> .


###  http://www.softlang.org/ontologies/fe#DataValidation
:DataValidation rdf:type owl:NamedIndividual ,
                         :DataManagementApproach ,
                         tbox:FormalEntity ;
                tbox:hasArea ce:SE ,
                             ce:SLE ;
                tbox:hasSpace ce:JSONware ,
                              ce:Ontoware ,
                              ce:SQLware ,
                              ce:XMLware ;
                foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Data_validation> ;
                rdfs:comment "data-management methodology concerned with checking data quality and conformance to constraints"@en ,
                             "data-management methodology concerned with ensuring that data conforms to structural and semantic expectations"@en ;
                rdfs:label "Data validation"@en .


###  http://www.softlang.org/ontologies/fe#DenotationalSemantics
:DenotationalSemantics rdf:type owl:NamedIndividual ,
                                :FormalSemanticsApproach ,
                                tbox:FormalEntity ;
                       tbox:hasArea ce:PLT ,
                                    ce:SLE ;
                       tbox:hasSpace ce:Programware ;
                       tbox:serves :MetaprogrammingApproach ,
                                   :ProgramTransformation ;
                       tbox:uses :AbstractSyntaxDefinitionApproach ,
                                 :DomainTheory ,
                                 :LambdaCalculus ;
                       foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Denotational_semantics> ;
                       rdfs:comment "formal-semantics approach based on mathematical denotations"@en ;
                       rdfs:label "Denotational semantics"@en .


###  http://www.softlang.org/ontologies/fe#DependencyGrammar
:DependencyGrammar rdf:type owl:NamedIndividual ,
                            :FormalGrammar ,
                            tbox:FormalEntity ;
                   tbox:hasArea ce:CL ,
                                ce:NLP ,
                                ce:TCS ;
                   tbox:hasSpace ce:Grammarware ;
                   foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Dependency_grammar> ;
                   rdfs:comment "grammar based on dependency relations"@en ;
                   rdfs:label "Dependency grammar"@en .


###  http://www.softlang.org/ontologies/fe#DependencyGraph
:DependencyGraph rdf:type owl:NamedIndividual ,
                          :DataStructure ,
                          tbox:FormalEntity ;
                 tbox:hasArea ce:SE ,
                              ce:SLE ;
                 tbox:hasSpace ce:Graphware ;
                 foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Dependency_graph> ;
                 rdfs:comment "data structure representing dependency relations among entities"@en ,
                              "data-structure notion of a graph used to represent dependency relationships"@en ;
                 rdfs:label "Dependency graph"@en .


###  http://www.softlang.org/ontologies/fe#DescriptionLogic
:DescriptionLogic rdf:type owl:NamedIndividual ,
                           tbox:FormalEntity ;
                  tbox:hasArea ce:KR ,
                               ce:TCS ;
                  tbox:hasSpace ce:Ontoware ;
                  foaf:page <https://en.wikipedia.org/wiki/Description_logic> .


###  http://www.softlang.org/ontologies/fe#DesignByContract
:DesignByContract rdf:type owl:NamedIndividual ,
                           :SoftwareDesignApproach ,
                           tbox:FormalEntity ;
                  tbox:hasArea ce:FM ,
                               ce:SE ,
                               ce:SLE ;
                  tbox:hasSpace ce:APIware ;
                  foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Design_by_contract> ;
                  rdfs:comment "software-design methodology based on explicit obligations, guarantees, and contracts"@en ,
                               "software-design methodology based on formally specified obligations and guarantees"@en ;
                  rdfs:label "Design by contract"@en .


###  http://www.softlang.org/ontologies/fe#DomainTheory
:DomainTheory rdf:type owl:NamedIndividual ,
                       tbox:FormalEntity ;
              tbox:hasArea ce:FM ,
                           ce:PLT ,
                           ce:TCS ;
              tbox:hasSpace ce:Programware ;
              foaf:page <https://en.wikipedia.org/wiki/Domain_theory> .


###  http://www.softlang.org/ontologies/fe#ELPlusPlus
:ELPlusPlus rdf:type owl:NamedIndividual ,
                     :DescriptionLogic ,
                     tbox:FormalEntity ;
            tbox:hasArea ce:KR ,
                         ce:TCS ;
            tbox:hasSpace ce:Ontoware ;
            foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/EL%2B%2B> ;
            rdfs:comment "lightweight description logic underlying the OWL 2 EL profile"@en ;
            rdfs:label "EL++"@en .


###  http://www.softlang.org/ontologies/fe#FirstOrderLogic
:FirstOrderLogic rdf:type owl:NamedIndividual ,
                          :FormalSystem ,
                          tbox:FormalEntity ;
                 tbox:hasArea ce:FM ,
                              ce:KR ,
                              ce:TCS ;
                 tbox:hasSpace ce:Logicware ;
                 foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/First-order_logic> ;
                 rdfs:comment "formal system based on quantified predicates over individuals"@en ;
                 rdfs:label "First-order logic"@en .


###  http://www.softlang.org/ontologies/fe#FormalGrammar
:FormalGrammar rdf:type owl:NamedIndividual ,
                        tbox:FormalEntity ;
               tbox:hasArea ce:CC ,
                            ce:SLE ,
                            ce:TCS ;
               tbox:hasSpace ce:Grammarware ;
               foaf:page <https://en.wikipedia.org/wiki/Formal_grammar> .


###  http://www.softlang.org/ontologies/fe#FormalObject
:FormalObject rdf:type owl:NamedIndividual ,
                       tbox:FormalEntity ;
              foaf:page <https://en.wikipedia.org/wiki/Formalism_(philosophy_of_mathematics)> .


###  http://www.softlang.org/ontologies/fe#FormalProof
:FormalProof rdf:type owl:NamedIndividual ,
                      :FormalObject ,
                      tbox:FormalEntity ;
             tbox:hasArea ce:FM ,
                          ce:KR ;
             tbox:hasSpace ce:Logicware ,
                           ce:Proofware ;
             foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Formal_proof> ;
             rdfs:comment "formal object representing a proof in a deductive system"@en ;
             rdfs:label "Formal proof"@en .


###  http://www.softlang.org/ontologies/fe#FormalSemanticsApproach
:FormalSemanticsApproach rdf:type owl:NamedIndividual ,
                                  tbox:FormalEntity ;
                         tbox:hasArea ce:CC ,
                                      ce:PLT ,
                                      ce:SLE ;
                         tbox:hasSpace ce:Programware ;
                         foaf:page <https://en.wikipedia.org/wiki/Semantics_(programming_languages)#Approaches> .


###  http://www.softlang.org/ontologies/fe#FormalSystem
:FormalSystem rdf:type owl:NamedIndividual ,
                       tbox:FormalEntity ;
              foaf:page <https://en.wikipedia.org/wiki/Formal_system> .


###  http://www.softlang.org/ontologies/fe#GenerativeGrammar
:GenerativeGrammar rdf:type owl:NamedIndividual ,
                            tbox:FormalEntity ;
                   tbox:hasArea ce:CC ,
                                ce:CL ,
                                ce:TCS ;
                   tbox:hasSpace ce:Grammarware ;
                   foaf:page <https://en.wikipedia.org/wiki/Formal_grammar#The_Chomsky_hierarchy> .


###  http://www.softlang.org/ontologies/fe#Graph
:Graph rdf:type owl:NamedIndividual ,
                :MathematicalStructure ,
                tbox:FormalEntity ;
       tbox:hasArea ce:FM ,
                    ce:TCS ;
       tbox:hasSpace ce:Graphware ;
       foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Graph_(discrete_mathematics)> ;
       rdfs:comment "mathematical structure consisting of vertices and edges"@en ;
       rdfs:label "Graph"@en .


###  http://www.softlang.org/ontologies/fe#GraphRewritingSystem
:GraphRewritingSystem rdf:type owl:NamedIndividual ,
                               :AbstractRewritingSystem ,
                               tbox:FormalEntity ;
                      tbox:hasArea ce:SLE ,
                                   ce:TCS ;
                      tbox:hasSpace ce:Graphware ;
                      foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Graph_rewriting> ;
                      rdfs:comment "rewriting system based on graph transformation rules"@en ;
                      rdfs:label "Graph rewriting system"@en .


###  http://www.softlang.org/ontologies/fe#GraphTheory
:GraphTheory rdf:type owl:NamedIndividual ,
                      :Theory ,
                      tbox:FormalEntity ;
             tbox:hasArea ce:FM ,
                          ce:TCS ;
             tbox:hasSpace ce:Graphware ;
             foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Graph_theory> ;
             rdfs:comment "mathematical theory of graphs and their properties"@en ;
             rdfs:label "Graph theory"@en .


###  http://www.softlang.org/ontologies/fe#HoareLogic
:HoareLogic rdf:type owl:NamedIndividual ,
                     :ProgramLogic ,
                     tbox:FormalEntity ;
            tbox:hasArea ce:FM ,
                         ce:PLT ;
            tbox:hasSpace ce:Programware ,
                          ce:Proofware ;
            foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Hoare_logic> ;
            rdfs:comment "program logic using Hoare triples"@en ;
            rdfs:label "Hoare logic"@en .


###  http://www.softlang.org/ontologies/fe#HornClause
:HornClause rdf:type owl:NamedIndividual ,
                     :FormalObject ,
                     tbox:FormalEntity ;
            tbox:hasArea ce:KR ,
                         ce:TCS ;
            tbox:hasSpace ce:Logicware ;
            foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Horn_clause> ;
            rdfs:comment "formal object consisting of a clause with at most one positive literal, important in logic programming"@en ;
