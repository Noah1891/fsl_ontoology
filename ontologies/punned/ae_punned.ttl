:APIDescriptionArtifact rdfs:label "API description artifact"@en .


:BuildScriptArtifact rdfs:comment "artifact kind for build scripts and build automation specifications"@en ;
                     rdfs:label "Build script artifact"@en .


:ConfigurationArtifact rdfs:comment "artifact kind for configuration files and related configuration-level assets"@en ;
                       rdfs:label "Configuration artifact"@en .


:GrammarArtifact rdfs:label "Grammar artifact"@en .


:GrammarOfGrammarsArtifact rdfs:label "Grammar of grammars artifact"@en .


:GraphQueryArtifact rdfs:label "Graph query artifact"@en .


:JSONDocumentArtifact rdfs:label "JSON document artifact"@en .


:JSONSchemaArtifact rdfs:label "JSON schema artifact"@en .


:LogicProgramArtifact rdfs:comment "artifact kind typically associated with logic-paradigm programming languages such as Prolog and Datalog"@en ;
                      rdfs:label "Logic-program artifact"@en .


:MarkupArtifact rdfs:label "Markup artifact"@en .


:MegamodelArtifact rdfs:label "Megamodel artifact"@en .


:MetamodelArtifact rdfs:label "Metamodel artifact"@en .


:ModelArtifact rdfs:label "Model artifact"@en .


:OntologyArtifact rdfs:label "Ontology artifact"@en .


:ProgramArtifact rdfs:label "Program artifact"@en .


:ProofArtifact rdfs:label "Proof artifact"@en .


:PropertyGraphArtifact rdfs:label "Property graph artifact"@en .


:RDFGraphArtifact rdfs:label "RDF graph artifact"@en .


:RelationalDataArtifact rdfs:label "Relational data artifact"@en .


:RelationalQueryArtifact rdfs:label "Relational query artifact"@en .


:RelationalSchemaArtifact rdfs:label "Relational schema artifact"@en .


:RequirementsArtifact rdfs:comment "artifact kind for requirements specifications and similar requirements-level documents or models"@en ;
                      rdfs:label "Requirements artifact"@en .


:RuleArtifact rdfs:label "Rule artifact"@en .


:SemanticDataArtifact rdfs:label "Semantic data artifact"@en .


:ShapeArtifact rdfs:label "Shape artifact"@en .


:XMLDocumentArtifact rdfs:label "XML document artifact"@en .


:XMLSchemaArtifact rdfs:label "XML schema artifact"@en .


#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :ModelArtifact
                :ProgramArtifact
                :SemanticDataArtifact
              )
] .


