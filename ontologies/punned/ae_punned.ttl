@prefix tbox: <http://www.softlang.org/ontologies/tbox#> .
@base <http://www.softlang.org/ontologies/ae> .

<http://www.softlang.org/ontologies/ae> rdf:type owl:Ontology ;
                                         owl:imports <http://www.softlang.org/ontologies/tbox> ;
                                         tbox:commentingPolicy "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
                                         tbox:formattingPolicy "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
                                         tbox:linkingPolicy "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
                                         tbox:metamodelingPolicy "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
                                         rdfs:comment "Sub-ontology / ABox for software artifacts"@en .

#################################################################
#    Classes
#################################################################

###  http://www.softlang.org/ontologies/ae#APIDescriptionArtifact
:APIDescriptionArtifact rdf:type owl:Class ;
                        rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#BuildScriptArtifact
:BuildScriptArtifact rdf:type owl:Class ;
                     rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#ConfigurationArtifact
:ConfigurationArtifact rdf:type owl:Class ;
                       rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#GrammarArtifact
:GrammarArtifact rdf:type owl:Class ;
                 rdfs:subClassOf tbox:SoftwareArtifact ;
                 owl:disjointWith :MetamodelArtifact .


###  http://www.softlang.org/ontologies/ae#GrammarOfGrammarsArtifact
:GrammarOfGrammarsArtifact rdf:type owl:Class ;
                           rdfs:subClassOf tbox:SoftwareArtifact ;
                           owl:disjointWith :MetamodelArtifact .


###  http://www.softlang.org/ontologies/ae#GraphQueryArtifact
:GraphQueryArtifact rdf:type owl:Class ;
                    rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#JSONDocumentArtifact
:JSONDocumentArtifact rdf:type owl:Class ;
                      rdfs:subClassOf tbox:SoftwareArtifact ;
                      owl:disjointWith :XMLDocumentArtifact .


###  http://www.softlang.org/ontologies/ae#JSONSchemaArtifact
:JSONSchemaArtifact rdf:type owl:Class ;
                    rdfs:subClassOf tbox:SoftwareArtifact ;
                    owl:disjointWith :XMLSchemaArtifact .


###  http://www.softlang.org/ontologies/ae#LogicProgramArtifact
:LogicProgramArtifact rdf:type owl:Class ;
                      rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#MarkupArtifact
:MarkupArtifact rdf:type owl:Class ;
                rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#MegamodelArtifact
:MegamodelArtifact rdf:type owl:Class ;
                   rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#MetamodelArtifact
:MetamodelArtifact rdf:type owl:Class ;
                   rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#ModelArtifact
:ModelArtifact rdf:type owl:Class ;
               rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#OntologyArtifact
:OntologyArtifact rdf:type owl:Class ;
                  rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#ProgramArtifact
:ProgramArtifact rdf:type owl:Class ;
                 rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#ProofArtifact
:ProofArtifact rdf:type owl:Class ;
               rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#PropertyGraphArtifact
:PropertyGraphArtifact rdf:type owl:Class ;
                       rdfs:subClassOf :SemanticDataArtifact .


###  http://www.softlang.org/ontologies/ae#RDFGraphArtifact
:RDFGraphArtifact rdf:type owl:Class ;
                  rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#RelationalDataArtifact
:RelationalDataArtifact rdf:type owl:Class ;
                        rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#RelationalQueryArtifact
:RelationalQueryArtifact rdf:type owl:Class ;
                         rdfs:subClassOf :SemanticDataArtifact .


###  http://www.softlang.org/ontologies/ae#RelationalSchemaArtifact
:RelationalSchemaArtifact rdf:type owl:Class ;
                          rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#RequirementsArtifact
:RequirementsArtifact rdf:type owl:Class ;
                      rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#RuleArtifact
:RuleArtifact rdf:type owl:Class ;
              rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#SemanticDataArtifact
:SemanticDataArtifact rdf:type owl:Class ;
                      rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#ShapeArtifact
:ShapeArtifact rdf:type owl:Class ;
               rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#XMLDocumentArtifact
:XMLDocumentArtifact rdf:type owl:Class ;
                     rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#XMLSchemaArtifact
:XMLSchemaArtifact rdf:type owl:Class ;
                   rdfs:subClassOf tbox:SoftwareArtifact .


#################################################################
#    Individuals
#################################################################

###  http://www.softlang.org/ontologies/ae#APIDescriptionArtifact
:APIDescriptionArtifact rdf:type owl:NamedIndividual ,
                                 tbox:ArtifactEntity ;
                        tbox:elementOf le:InterfaceDescriptionLanguage .


###  http://www.softlang.org/ontologies/ae#BuildScriptArtifact
:BuildScriptArtifact rdf:type owl:NamedIndividual ,
                              tbox:ArtifactEntity ;
                     tbox:elementOf le:BuildScriptingLanguage ;
                     foaf:page <https://en.wikipedia.org/wiki/Build_automation> .


###  http://www.softlang.org/ontologies/ae#ConfigurationArtifact
:ConfigurationArtifact rdf:type owl:NamedIndividual ,
                                tbox:ArtifactEntity ;
                       tbox:elementOf le:ConfigurationLanguage ;
                       foaf:page <https://en.wikipedia.org/wiki/Configuration_file> .


###  http://www.softlang.org/ontologies/ae#GrammarArtifact
:GrammarArtifact rdf:type owl:NamedIndividual ,
                          tbox:ArtifactEntity ;
                 tbox:conformsTo :GrammarOfGrammarsArtifact ;
                 tbox:elementOf le:GrammarMetalanguage .


###  http://www.softlang.org/ontologies/ae#GrammarOfGrammarsArtifact
:GrammarOfGrammarsArtifact rdf:type owl:NamedIndividual ,
                                    tbox:ArtifactEntity ;
                           tbox:defines le:GrammarMetalanguage ;
                           tbox:elementOf le:GrammarMetalanguage .


###  http://www.softlang.org/ontologies/ae#GraphQueryArtifact
:GraphQueryArtifact rdf:type owl:NamedIndividual ,
                             tbox:ArtifactEntity ;
                    tbox:elementOf le:GraphQueryLanguage .


###  http://www.softlang.org/ontologies/ae#JSONDocumentArtifact
:JSONDocumentArtifact rdf:type owl:NamedIndividual ,
                               tbox:ArtifactEntity ;
                      tbox:conformsTo :JSONSchemaArtifact ;
                      tbox:elementOf le:JSON .


###  http://www.softlang.org/ontologies/ae#JSONSchemaArtifact
:JSONSchemaArtifact rdf:type owl:NamedIndividual ,
                             tbox:ArtifactEntity ;
                    tbox:classifies :JSONDocumentArtifact ;
                    tbox:elementOf le:JSONSchemaLanguage .


###  http://www.softlang.org/ontologies/ae#LogicProgramArtifact
:LogicProgramArtifact rdf:type owl:NamedIndividual ,
                               tbox:ArtifactEntity ;
                      tbox:elementOf pe:ProgrammingLanguage .


###  http://www.softlang.org/ontologies/ae#MarkupArtifact
:MarkupArtifact rdf:type owl:NamedIndividual ,
                         tbox:ArtifactEntity ;
                tbox:elementOf le:MarkupLanguage .


###  http://www.softlang.org/ontologies/ae#MegamodelArtifact
:MegamodelArtifact rdf:type owl:NamedIndividual ,
                            tbox:ArtifactEntity ;
                   tbox:elementOf le:MegamodelingLanguage ;
                   tbox:hasBibTeX "FavreLaemmelVaranovich2012LinguisticArchitecture" ,
                                  "FavreNguyen2004MegamodelEvolution" .


###  http://www.softlang.org/ontologies/ae#MetamodelArtifact
:MetamodelArtifact rdf:type owl:NamedIndividual ,
                            tbox:ArtifactEntity ;
                   tbox:elementOf le:MetamodelingLanguage .


###  http://www.softlang.org/ontologies/ae#ModelArtifact
:ModelArtifact rdf:type owl:NamedIndividual ,
                        tbox:ArtifactEntity ;
               tbox:conformsTo :MetamodelArtifact ;
               tbox:elementOf le:ModelingLanguage .


###  http://www.softlang.org/ontologies/ae#OntologyArtifact
:OntologyArtifact rdf:type owl:NamedIndividual ,
                           tbox:ArtifactEntity ;
                  tbox:classifies :RDFGraphArtifact ;
                  tbox:elementOf le:OntologyLanguage .


###  http://www.softlang.org/ontologies/ae#ProgramArtifact
:ProgramArtifact rdf:type owl:NamedIndividual ,
                          tbox:ArtifactEntity ;
                 tbox:elementOf pe:ProgrammingLanguage .


###  http://www.softlang.org/ontologies/ae#ProofArtifact
:ProofArtifact rdf:type owl:NamedIndividual ,
                        tbox:ArtifactEntity ;
               tbox:elementOf le:ProofLanguage .


###  http://www.softlang.org/ontologies/ae#PropertyGraphArtifact
:PropertyGraphArtifact rdf:type owl:NamedIndividual ,
                                tbox:ArtifactEntity ;
                       tbox:elementOf le:PropertyGraphDataModelLanguage .


###  http://www.softlang.org/ontologies/ae#RDFGraphArtifact
:RDFGraphArtifact rdf:type owl:NamedIndividual ,
                           tbox:ArtifactEntity ;
                  tbox:conformsTo :ShapeArtifact ;
                  tbox:elementOf le:RDF .


###  http://www.softlang.org/ontologies/ae#RelationalDataArtifact
:RelationalDataArtifact rdf:type owl:NamedIndividual ,
                                 tbox:ArtifactEntity ;
                        tbox:conformsTo :RelationalSchemaArtifact ;
                        tbox:elementOf le:SQLDML .


###  http://www.softlang.org/ontologies/ae#RelationalQueryArtifact
:RelationalQueryArtifact rdf:type owl:NamedIndividual ,
                                  tbox:ArtifactEntity ;
                         tbox:elementOf le:SQLQuery .


###  http://www.softlang.org/ontologies/ae#RelationalSchemaArtifact
:RelationalSchemaArtifact rdf:type owl:NamedIndividual ,
                                   tbox:ArtifactEntity ;
                          tbox:classifies :RelationalDataArtifact ;
                          tbox:elementOf le:SQLDDL .


###  http://www.softlang.org/ontologies/ae#RequirementsArtifact
:RequirementsArtifact rdf:type owl:NamedIndividual ,
                               tbox:ArtifactEntity ;
                      tbox:elementOf le:RequirementsSpecificationLanguage ;
                      foaf:page <https://en.wikipedia.org/wiki/Software_requirements_specification> .


###  http://www.softlang.org/ontologies/ae#RuleArtifact
:RuleArtifact rdf:type owl:NamedIndividual ,
                       tbox:ArtifactEntity ;
              tbox:elementOf le:RuleLanguage .


###  http://www.softlang.org/ontologies/ae#SemanticDataArtifact
:SemanticDataArtifact rdf:type owl:NamedIndividual ,
                               tbox:ArtifactEntity .


###  http://www.softlang.org/ontologies/ae#ShapeArtifact
:ShapeArtifact rdf:type owl:NamedIndividual ,
                        tbox:ArtifactEntity ;
               tbox:classifies :RDFGraphArtifact ;
               tbox:elementOf le:ConstraintLanguage .


###  http://www.softlang.org/ontologies/ae#XMLDocumentArtifact
:XMLDocumentArtifact rdf:type owl:NamedIndividual ,
                              tbox:ArtifactEntity ;
                     tbox:conformsTo :XMLSchemaArtifact ;
                     tbox:elementOf le:XML .


###  http://www.softlang.org/ontologies/ae#XMLSchemaArtifact
:XMLSchemaArtifact rdf:type owl:NamedIndividual ,
                            tbox:ArtifactEntity ;
                   tbox:classifies :XMLDocumentArtifact ;
                   tbox:elementOf le:XMLSchemaLanguage .


