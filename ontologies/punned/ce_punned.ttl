###  http://www.softlang.org/ontologies/ce#APIDesign
:APIDesign rdf:type owl:NamedIndividual ,
                    tbox:ConceptualEntity ;
           tbox:hasOutputArtifact ae:APIDescriptionArtifact ;
           tbox:hasSupportingLanguage le:InterfaceDescriptionLanguage ;
           tbox:hasSupportingTool te:APIWorkbench ;
           tbox:uses fe:SoftwareDesignApproach ;
           foaf:page <https://en.wikipedia.org/wiki/API> .


###  http://www.softlang.org/ontologies/ce#APIware
:APIware rdf:type owl:NamedIndividual ,
                  tbox:ConceptualEntity ,
                  tbox:TechnologicalSpace ;
         tbox:hasArtifact ae:APIDescriptionArtifact ;
         tbox:hasTool te:APIWorkbench ,
                      te:TransformationEngine ,
                      te:Validator ;
         rdfs:comment "technological space centered on interface descriptions, service contracts, API documentation, and contract-oriented tooling"@en ;
         rdfs:label "APIware"@en .


###  http://www.softlang.org/ontologies/ce#Abstraction
:Abstraction rdf:type owl:NamedIndividual ,
                      :AbstractionConcept ,
                      tbox:ConceptualEntity ;
